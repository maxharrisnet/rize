---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  /** Extra classes, e.g. aspect ratio (`aspect-[4/3]`) or sizing. */
  class?: string;
  sizes?: string;
  widths?: number[];
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  class: className,
  sizes = '(min-width: 768px) 50vw, 100vw',
  widths = [480, 800, 1200, 1600],
  loading = 'lazy',
} = Astro.props;
---
<Image
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  loading={loading}
  class:list={[
    'w-full rounded-[14px] border-2 border-ink object-cover',
    className,
  ]}
/>
