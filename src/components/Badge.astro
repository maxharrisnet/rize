---
interface Props { label: string; }
const { label } = Astro.props;
---
<div class="relative h-28 w-28 shrink-0">
  <div class="badge-ring absolute inset-0 rounded-full border-[3px] border-dashed border-brand-red"></div>
  <div class="absolute inset-0 flex items-center justify-center px-3 text-center font-black uppercase leading-none text-ink" style="font-size:1.125rem">{label}</div>
</div>
<style>
  .badge-ring { animation: badge-spin 9s linear infinite; }
  @keyframes badge-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .badge-ring { animation: none; } }
</style>
