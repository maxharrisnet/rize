---
interface Tier { name: string; price: string; detail: string; }
interface AddOn { name: string; price: string; }
interface Props { tiers: Tier[]; addOns?: AddOn[]; accent?: 'red' | 'blue'; }
const { tiers, addOns, accent = 'red' } = Astro.props;
const ring = accent === 'red' ? 'border-brand-red' : 'border-brand-blue';
---
<div class="grid gap-6 md:grid-cols-3">
  {tiers.map((t) => (
    <div class:list={["rounded-[14px] border-2 bg-white p-6", ring]}>
      <h4 class="text-h3">{t.name}</h4>
      <p class="mt-2 text-h3 font-black">{t.price}</p>
      <p class="mt-3 text-body text-body-muted">{t.detail}</p>
    </div>
  ))}
</div>
{addOns && (
  <div class="mt-8">
    <h3 class="text-h3 mb-4">Add-ons</h3>
    <ul class="grid gap-2 sm:grid-cols-2">
      {addOns.map((a) => (
        <li class="flex justify-between rounded-[10px] border-2 border-ink bg-white px-4 py-3">
          <span class="text-body">{a.name}</span><span class="text-body font-bold">{a.price}</span>
        </li>
      ))}
    </ul>
  </div>
)}
