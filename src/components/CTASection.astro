---
interface Props { title: string; }
const { title } = Astro.props;
---
<section class="bg-ink text-cream">
  <div class="container-wide py-20 text-center">
    <h2 class="text-h2 mb-6 text-brand-gold">{title}</h2>
    <div class="text-body-lg max-w-2xl mx-auto mb-8"><slot name="body" /></div>
    <div class="flex flex-wrap gap-4 justify-center"><slot name="actions" /></div>
  </div>
</section>
