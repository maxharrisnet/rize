---
interface Anchor { label: string; href: string; }
interface Props { anchors: Anchor[]; }
const { anchors } = Astro.props;
---
<nav class="sticky top-16 z-40 bg-cream/95 backdrop-blur border-y border-stone-200">
  <div class="container-wide flex gap-6 overflow-x-auto py-3 text-base font-bold uppercase tracking-[0.02em]">
    {anchors.map((a) => <a href={a.href} class="whitespace-nowrap decoration-brand-red decoration-2 underline-offset-[6px] hover:underline">{a.label}</a>)}
  </div>
</nav>
