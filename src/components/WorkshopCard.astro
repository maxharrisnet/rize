---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
interface Props { workshop: CollectionEntry<'workshops'>['data']; slug: string; }
const { workshop, slug } = Astro.props;
const isCommunity = workshop.track === 'community';
const bg = isCommunity ? 'bg-brand-red' : 'bg-brand-blue';
const chipText = isCommunity ? 'text-brand-red' : 'text-brand-blue';
const icon = isCommunity ? 'ph:hand-heart-bold' : 'ph:rocket-launch-bold';
---
<a
  href={`/workshops/${slug}`}
  class:list={["group flex h-full flex-col rounded-[14px] border-2 border-ink p-6 text-white transition-transform hover:-translate-y-1 md:p-8", bg]}
>
  <div class="flex items-center gap-4">
    <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white text-3xl", chipText]}>
      <Icon name={icon} />
    </span>
    <h3 class="text-h3">{workshop.title}</h3>
  </div>
  <p class="mt-4 flex-1 text-body-lg">{workshop.tagline}</p>
  <span class="mt-6 font-bold uppercase tracking-[0.08em] group-hover:underline">See workshop details &rarr;</span>
</a>
