---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
interface Props { course: CollectionEntry<'courses'>['data']; }
const { course } = Astro.props;
---
<article class="h-full rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
  <span class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-gold text-ink text-3xl">
    <Icon name="ph:graduation-cap-bold" />
  </span>
  <h3 class="text-h3 mt-4">{course.title}</h3>
  <p class="mt-2 text-body-lg text-body-muted">{course.tagline}</p>
  <div class="mt-6 grid gap-6 md:grid-cols-3">
    <div>
      <h4 class="text-eyebrow font-bold text-ink">Who this course is for</h4>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-body text-body-muted">{course.whoFor.map((i) => <li>{i}</li>)}</ul>
    </div>
    <div>
      <h4 class="text-eyebrow font-bold text-ink">Topics covered</h4>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-body text-body-muted">{course.topics.map((i) => <li>{i}</li>)}</ul>
    </div>
    <div>
      <h4 class="text-eyebrow font-bold text-ink">What you will walk away with</h4>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-body text-body-muted">{course.outcomes.map((i) => <li>{i}</li>)}</ul>
    </div>
  </div>
</article>
