---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
interface Props { course: CollectionEntry<'courses'>['data']; slug: string; }
const { course, slug } = Astro.props;
---
<a
  href={`/courses/${slug}`}
  class="group flex h-full flex-col rounded-[14px] border-2 border-ink bg-white p-6 transition-transform hover:-translate-y-1 md:p-8"
>
  <div class="flex items-center gap-4">
    <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-gold text-ink text-3xl">
      <Icon name="ph:graduation-cap-bold" />
    </span>
    <h3 class="text-h3">{course.title}</h3>
  </div>
  <p class="mt-4 flex-1 text-body-lg text-body-muted">{course.tagline}</p>
  <p class="mt-4 text-eyebrow font-bold uppercase tracking-[0.04em] text-meta-muted">{course.topics.length} topics &middot; multi-session</p>
  <span class="mt-6 font-bold uppercase tracking-[0.08em] text-brand-red group-hover:underline">See course details &rarr;</span>
</a>
