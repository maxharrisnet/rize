---
interface Item {
  label: string;
  href: string;
  count: number;
}
interface Props { items: Item[]; }
const { items } = Astro.props;
---
<div class="pathnav-sentinel" aria-hidden="true"></div>
<nav class="pathnav sticky top-16 z-40" aria-label="Learning paths">
  <div class="container-wide">
    <div class="pathnav-grid grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4">
      {items.map((item) => (
        <a href={item.href} class="pathnav-tile border-2 border-ink bg-white text-ink">
          <span class="pathnav-title">{item.label}</span>
          <span class="pathnav-count">{item.count} programs</span>
        </a>
      ))}
    </div>
  </div>
</nav>
<style>
  .pathnav {
    padding-block: 1rem;
    transition: background-color 0.3s ease, padding 0.3s ease;
  }
  .pathnav-grid {
    gap: 1.25rem;
    transition: gap 0.3s ease;
  }
  .pathnav-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.5rem;
    min-height: 9rem;
    border-radius: 14px;
    padding: 1.25rem 1rem;
    text-decoration: none;
    text-transform: uppercase;
    transition: padding 0.3s ease, border-radius 0.3s ease, min-height 0.3s ease,
      transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }
  .pathnav-tile:hover {
    background-color: var(--color-ink);
    color: var(--color-cream);
    transform: translateY(-3px);
  }
  .pathnav-tile:focus-visible { outline: 3px solid var(--color-brand-blue); outline-offset: 2px; }
  .pathnav-title {
    font-size: clamp(1.125rem, 0.95rem + 0.5vw, 1.25rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.01em;
    hyphens: auto;
    transition: font-size 0.3s ease, font-weight 0.3s ease;
  }
  .pathnav-count {
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    opacity: 0.75;
    transition: opacity 0.15s ease;
  }

  .pathnav.is-stuck {
    padding-block: 0.5rem;
    background: color-mix(in srgb, var(--color-cream) 95%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-stone-200);
  }
  .pathnav.is-stuck .pathnav-grid { gap: 0.5rem; }
  @media (min-width: 768px) {
    .pathnav.is-stuck .pathnav-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  @media (max-width: 39.99rem) {
    .pathnav-tile { min-height: 4.5rem; }
    .pathnav.is-stuck .pathnav-grid { display: flex; overflow-x: auto; }
    .pathnav.is-stuck .pathnav-tile { flex: 0 0 auto; }
  }
  .pathnav.is-stuck .pathnav-tile {
    min-height: 0;
    border-radius: 10px;
    padding: 0.5rem 1rem;
  }
  .pathnav.is-stuck .pathnav-title {
    font-size: 1.125rem;
    font-weight: 700;
  }
  .pathnav.is-stuck .pathnav-count {
    opacity: 0;
    position: absolute;
    pointer-events: none;
  }
</style>
<script>
  const nav = document.querySelector('.pathnav');
  const sentinel = document.querySelector('.pathnav-sentinel');
  if (nav && sentinel) {
    // Header is sticky at 64px; compact the nav once the sentinel passes under it.
    let ticking = false;
    const update = () => {
      nav.classList.toggle('is-stuck', sentinel.getBoundingClientRect().top < 65);
      ticking = false;
    };
    addEventListener('scroll', () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }, { passive: true });
    update();
  }
</script>
