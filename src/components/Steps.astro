---
interface Step { title: string; body: string; }
interface Props { steps: Step[]; }
const { steps } = Astro.props;
---
<ol class="grid gap-6 md:grid-cols-2">
  {steps.map((s, i) => (
    <li class="rounded-[14px] border-2 border-ink bg-white p-6">
      <div class="flex items-center gap-4">
        <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-gold text-ink font-black text-3xl">{i + 1}</span>
        <h3 class="text-h3">{s.title}</h3>
      </div>
      <p class="mt-4 text-body text-body-muted">{s.body}</p>
    </li>
  ))}
</ol>
