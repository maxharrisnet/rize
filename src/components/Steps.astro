---
interface Step { title: string; body: string; }
interface Props { steps: Step[]; }
const { steps } = Astro.props;
---
<ol class="grid gap-6 md:grid-cols-2">
  {steps.map((s, i) => (
    <li class="rounded-[14px] border-2 border-ink bg-white p-6">
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-brand-gold text-ink font-black text-xl">{i + 1}</span>
      <h3 class="text-h3 mt-4">{s.title}</h3>
      <p class="mt-2 text-body text-body-muted">{s.body}</p>
    </li>
  ))}
</ol>
