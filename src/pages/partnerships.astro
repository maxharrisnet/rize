---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AnchorNav from '../components/AnchorNav.astro';
import IconList from '../components/IconList.astro';
import Steps from '../components/Steps.astro';
import CTASection from '../components/CTASection.astro';
import Photo from '../components/Photo.astro';
import communityPlanning from '../assets/images/community-planning.jpg';
import grantPlanning from '../assets/images/grant-planning.jpg';

const chipClass = { red: 'bg-brand-red text-white', ink: 'bg-ink text-cream' } as const;

const partnerTypes: { label: string; icon: string; accent: 'red' | 'ink' }[] = [
  { label: 'Nonprofits and charities', icon: 'ph:hand-heart-bold', accent: 'red' },
  { label: 'Community organizations and community-led groups', icon: 'ph:users-three-bold', accent: 'ink' },
  { label: 'Social service, settlement, and employment organizations', icon: 'ph:lifebuoy-bold', accent: 'red' },
  { label: 'Libraries and public-serving community spaces', icon: 'ph:books-bold', accent: 'ink' },
  { label: 'Indigenous-led groups and nations', icon: 'ph:handshake-bold', accent: 'red' },
  { label: 'Black-led community organizations', icon: 'ph:buildings-bold', accent: 'ink' },
];

const components = [
  'Workshops on digital confidence, digital safety, AI, modern work, and related topics.',
  'Multi-session series for deeper transformation, including organizational capacity-building programs.',
  'Tailored delivery for a specific audience, cohort, or community context.',
  'Optional supporting services such as websites, internal systems, or grant-writing support when the engagement calls for it.',
];

const fundingHelp = [
  'Identifying relevant funding opportunities.',
  'Shaping a program to fit the opportunity.',
  'Supporting application language and documentation where appropriate.',
  'Delivering the actual program once the work is approved or scoped.',
];

const steps = [
  { title: 'Reach out', body: 'Share who you serve, what your goals are, and what kind of support you think may help.' },
  { title: 'We design together', body: 'We identify the right format, topics, audience fit, and possible funding path where relevant.' },
  { title: 'We deliver', body: 'Rize handles curriculum, facilitation, and materials, with delivery shaped for your community and context.' },
  { title: 'You keep the momentum', body: 'Participants leave with practical tools and reference material, and organizations can continue with follow-up support, further training, or systems implementation if needed.' },
];

const outcomes = [
  'A program shaped to the actual needs of your community.',
  'Participants who leave with more confidence and usable skills.',
  'Resources and materials that help learning continue after the session.',
  'In some engagements, stronger internal systems, clearer workflows, or next-step implementation support.',
];
---
<BaseLayout
  title="Partnerships | Funded Technology Education for Communities in Vancouver"
  description="Rize partners with community organizations, nonprofits, and trusted groups to deliver workshops, series, and support that build real confidence with technology — often with funding that makes the work possible."
>
  <Hero title="Partnerships that bring practical<br />technology education to your community.">
    <Fragment slot="lead">
      <p>Rize partners with community organizations, nonprofits, and other trusted groups to deliver workshops, series, and related support that help people build real confidence with technology. In many cases, we also help identify funding opportunities that can make the work possible at little or no cost to the organization or participants.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/book">Talk About a Partnership</Button>
      <Button href="/book#intake" variant="secondary">Book a Discovery Call</Button>
    </Fragment>
  </Hero>

  <AnchorNav anchors={[
    { label: "Who It's For", href: '#who-its-for' },
    { label: 'What It Includes', href: '#includes' },
    { label: 'Funding', href: '#funding' },
    { label: 'How It Works', href: '#how-it-works' },
    { label: 'Outcomes', href: '#outcomes' },
  ]} />

  <section id="who-its-for" class="container-wide scroll-mt-24 py-16 md:py-24">
    <SectionHeading eyebrow="Who It's For" title="Who partnerships are for.">
      <p>Rize works best with organizations that already have trust and relationships in the communities they serve.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2">
      {partnerTypes.map((p) => (
        <div class="flex h-full items-center gap-4 rounded-[14px] border-2 border-ink bg-white p-6">
          <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipClass[p.accent]]}>
            <Icon name={p.icon} />
          </span>
          <p class="text-body-lg font-bold text-ink">{p.label}</p>
        </div>
      ))}
    </div>
    <div class="mt-8 rounded-[14px] border-2 border-ink bg-ink p-8 text-cream md:p-10">
      <p class="text-body-lg">You bring the community, the trust, and the local knowledge. Rize brings the curriculum, facilitation, technology guidance, and partnership support needed to deliver something genuinely useful.</p>
    </div>
  </section>

  <section id="includes" class="container-wide scroll-mt-24 py-16 md:py-24">
    <SectionHeading eyebrow="What It Includes" title="What partnership can include.">
      <p>Partnerships can be as light or as deep as the context calls for.</p>
    </SectionHeading>
    <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
      <h3 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Core partnership components</h3>
      <div class="mt-5"><IconList items={components} /></div>
    </div>
  </section>

  <section id="funding" class="container-wide scroll-mt-24 py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <SectionHeading eyebrow="Funding" title="Funding and affordability.">
        <p>Many organizations want to deliver this kind of training but assume it will be out of reach. In practice, some community-focused digital skills and AI upskilling work can be supported through existing provincial or federal funding streams, depending on the audience, geography, and program goals.</p>
      </SectionHeading>
      <Photo
        src={grantPlanning}
        alt="Two colleagues reviewing a grant application together at a work table"
        class="aspect-[4/3]"
      />
    </div>
    <div class="mt-8 rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
      <h3 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">What Rize can help with</h3>
      <div class="mt-5"><IconList items={fundingHelp} /></div>
    </div>
  </section>

  <section id="how-it-works" class="container-wide scroll-mt-24 py-16 md:py-24">
    <SectionHeading eyebrow="How It Works" title="How it works.">
      <p>Simple and low-friction, from the first conversation to the last session.</p>
    </SectionHeading>
    <Steps steps={steps} />
  </section>

  <section id="outcomes" class="container-wide scroll-mt-24 py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <Photo
        src={communityPlanning}
        alt="A community group planning a program together around a table"
        class="aspect-[4/3] md:order-last"
      />
      <div>
        <SectionHeading eyebrow="Outcomes" title="What partners walk away with." />
        <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
          <IconList items={outcomes} />
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide pb-16 md:pb-24">
    <div class="rounded-[14px] border-2 border-ink bg-brand-gold p-8 text-ink md:p-12">
      <h2 class="text-h2">Why this model works.</h2>
      <p class="mt-6 max-w-3xl text-body-lg">People learn best in places where they already feel supported. Community organizations understand their people, their barriers, and their goals. Rize's role is to bring practical technology education into those spaces in a way that feels useful, respectful, and grounded in real life.</p>
    </div>
  </section>

  <CTASection title="Start the conversation.">
    <Fragment slot="body">
      <p>If you are interested in a workshop, a series, a funded partnership, or a broader implementation project, we would love to hear from you.</p>
      <p class="mt-4"><a href="mailto:holler@weallrize.ca" class="underline hover:no-underline">holler@weallrize.ca</a></p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/book">Talk About a Partnership</Button>
      <Button href="/book#intake" variant="secondary">Book a Discovery Call</Button>
    </Fragment>
  </CTASection>
</BaseLayout>
