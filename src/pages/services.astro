---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AnchorNav from '../components/AnchorNav.astro';
import PricingTable from '../components/PricingTable.astro';

const orgTiers = [
  { name: 'Starter', price: 'from $750', detail: 'Up to 5 pages.' },
  { name: 'Standard', price: 'from $1,500', detail: 'Up to 10 pages, events or blog section, email integration.' },
  { name: 'Growth', price: 'from $2,500', detail: 'Up to 20 pages, donation system, custom content types, team training.' },
];
const bizTiers = [
  { name: 'Starter', price: 'from $750', detail: 'Up to 5 pages.' },
  { name: 'Standard', price: 'from $1,500', detail: 'Up to 10 pages, blog or booking integration, CRM setup.' },
  { name: 'Growth', price: 'from $2,500', detail: 'Up to 20 pages, custom features, automations, team training.' },
];
const bizAddOns = [
  { name: 'AI-assisted copywriting (up to 5 pages)', price: '$300' },
  { name: 'Brand identity (logo, colors, fonts, usage guide)', price: '$400' },
  { name: 'Bilingual site (English + French or other)', price: 'from $500' },
  { name: 'Accessibility audit and remediation', price: '$350' },
  { name: 'Local SEO and AI visibility package', price: 'from $400' },
  { name: 'Ongoing maintenance and support', price: 'from $150/month' },
];
---
<BaseLayout
  title="Website & Automation Services | Rize Skill Training Vancouver"
  description="Websites, automation systems, and digital marketing for community organizations, nonprofits, small businesses, and entrepreneurs in Vancouver. Clear pricing."
>
  <Hero title="Services that make<br />your organization stronger.">
    <Fragment slot="lead">
      <p>Beyond training, we build websites, automation systems, and digital marketing solutions for community organizations, nonprofits, small businesses, and entrepreneurs across Vancouver and the surrounding area. Professional results, accessible process, clear pricing.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Book a Free Discovery Call</Button>
    </Fragment>
  </Hero>

  <AnchorNav anchors={[
    { label: 'For Organizations', href: '#organizations' },
    { label: 'For Businesses', href: '#businesses' },
    { label: 'Integrations and Automations', href: '#automations' },
    { label: 'Growth and Outreach', href: '#growth' },
  ]} />

  <section class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <SectionHeading title="How it works.">
      <p>Every service engagement starts with a free 20-minute discovery call. We learn about your organization, your goals, and your current setup — and give you an honest picture of what would actually help and what it would cost.</p>
    </SectionHeading>
    <ul class="list-disc pl-5 text-stone-700 space-y-1">
      <li>Discovery call — 20 minutes, free, no commitment</li>
      <li>Proposal — clear scope, clear price, plain language</li>
      <li>Build and deliver — we do the work and keep you informed throughout</li>
      <li>Handoff and training — we walk your team through everything so you can own it</li>
    </ul>
    <div class="mt-6">
      <Button href="/contact">Book a Free Discovery Call</Button>
    </div>
  </section>

  <section id="organizations" class="bg-stone-100">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-24">
      <SectionHeading title="For Organizations.">
        <p>Nonprofit organizations, charities, community groups, and social service agencies have specific needs — donation systems, event management, volunteer coordination, and a presence that communicates mission and builds trust. We build websites and systems designed around those needs, with training included so your team can manage everything independently.</p>
        <p>We also offer grant writing assistance as part of our funded partnership model — helping organizations identify and apply for the funding that can cover the cost of digital skills training, technology setup, and more.</p>
      </SectionHeading>

      <div class="mt-8">
        <h3 class="text-2xl">Community and Nonprofit Websites</h3>
        <p class="mt-2 text-stone-700">A website that tells your story, showcases your programs, connects people to your mission, and makes it easy to donate, register, or get involved. Built on WordPress so your team can update content without needing a developer.</p>
        <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
          <li>Donation integration — Canada Helps, Stripe, PayPal — including recurring giving</li>
          <li>Event listings and program pages with past and upcoming date handling</li>
          <li>Volunteer management and contact forms</li>
          <li>Email newsletter signup and donor communication tools</li>
          <li>Accessible design (WCAG 2.1) and mobile-first build</li>
        </ul>
      </div>

      <div class="mt-8">
        <h3 class="text-2xl">Events and Programming Sites</h3>
        <p class="mt-2 text-stone-700">For organizations running regular events, workshops, or community programming. A site that sells tickets, builds your audience, drives attendance, and keeps your community informed.</p>
        <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
          <li>Event listings with ticket integration — Eventbrite, Ticket Tailor</li>
          <li>Program and registration pages</li>
          <li>Sponsor recognition and gallery sections</li>
          <li>Email and social media integration</li>
        </ul>
      </div>

      <div class="mt-8">
        <h3 class="text-2xl">Grant Writing Assistance</h3>
        <p class="mt-2 text-stone-700">We help organizations identify the provincial and federal funding available for digital skills training and AI upskilling — and assist with the application process. This service is often what makes a funded partnership possible in the first place.</p>
        <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
          <li>Funding source identification for your organization type and community</li>
          <li>Application support and co-writing</li>
          <li>Program design documentation for grant submissions</li>
          <li>Reporting templates for funded programs</li>
        </ul>
      </div>

      <h3 class="text-2xl mt-10">Pricing</h3>
      <p class="text-stone-500 italic">All projects start with a discovery call. Pricing based on scope, complexity, and timeline.</p>
      <div class="mt-6">
        <PricingTable tiers={orgTiers} accent="red" />
      </div>

      <div class="mt-8">
        <Button href="/contact">Book a Discovery Call</Button>
      </div>
    </div>
  </section>

  <section id="businesses" class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <SectionHeading title="For Businesses.">
      <p>Small businesses, independent service providers, and entrepreneurs need websites that bring the right people to them — and systems that keep operations running without constant manual effort. We build both, with a focus on local search visibility and integrations that actually reduce your workload.</p>
    </SectionHeading>

    <div class="mt-8">
      <h3 class="text-2xl">Booking and Appointment Sites</h3>
      <p class="mt-2 text-stone-700">For service providers who want clients to book time with them online — saving hours of back-and-forth every week and keeping your calendar full without manual coordination.</p>
      <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
        <li>Online booking — Calendly, Acuity, Square Appointments</li>
        <li>Service listings and pricing pages</li>
        <li>Client intake forms and automated confirmation emails</li>
        <li>Team pages and availability management</li>
      </ul>
    </div>

    <div class="mt-8">
      <h3 class="text-2xl">Local Business Sites</h3>
      <p class="mt-2 text-stone-700">For brick-and-mortar businesses and local service providers who want to be found, trusted, and contacted by people in their neighborhood. Strong local search and AI visibility means you show up when and where it matters.</p>
      <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
        <li>Google Maps and Google Business Profile setup and optimization</li>
        <li>Local SEO and AI search optimization — showing up in Google, maps, and AI-generated answers</li>
        <li>Hours, location, and click-to-call setup</li>
        <li>Menu, service listings, and photo galleries</li>
      </ul>
    </div>

    <div class="mt-8">
      <h3 class="text-2xl">Creative Portfolio Sites</h3>
      <p class="mt-2 text-stone-700">For musicians, photographers, videographers, designers, and other creative professionals who need a home for their work that makes an impression and gets them hired or booked.</p>
      <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
        <li>Gallery and portfolio display</li>
        <li>Music and video embeds — Spotify, SoundCloud, Vimeo, YouTube</li>
        <li>Press kit and media download pages</li>
        <li>Booking and contact integration</li>
      </ul>
    </div>

    <h3 class="text-2xl mt-10">Pricing</h3>
    <p class="text-stone-500 italic">All projects start with a discovery call. Pricing based on scope, complexity, and timeline.</p>
    <div class="mt-6">
      <PricingTable tiers={bizTiers} addOns={bizAddOns} accent="blue" />
    </div>

    <div class="mt-8">
      <Button href="/contact">Book a Discovery Call</Button>
    </div>
  </section>

  <section id="automations" class="bg-stone-100">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-24">
      <SectionHeading title="Integrations and Automations.">
        <p>The biggest opportunity most organizations are missing is connecting the tools they already use so that information flows automatically, tasks happen without manual triggers, and their team spends more time on the work that matters.</p>
        <p>We assess what you have, identify where the friction is, and build workflows that handle the repetitive work. Using tools like n8n, Zapier, Claude AI, and Slack, we create integrations that are reliable, maintainable, and built for your team to own — not dependent on us indefinitely.</p>
      </SectionHeading>

      <h3 class="text-2xl mt-8">What we connect</h3>
      <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
        <li>CRM systems — HubSpot, Mailchimp — to your website, email, and lead capture</li>
        <li>Booking and scheduling tools to your calendar and client communications</li>
        <li>Donation and payment platforms to your website and donor follow-up</li>
        <li>Social media and email marketing to your content workflow</li>
        <li>Internal tools — Slack, Microsoft Teams — to your task and project management</li>
        <li>AI tools — Claude, ChatGPT — to your content creation and research workflows</li>
        <li>Google Workspace and Microsoft 365 to your team's daily operations</li>
      </ul>

      <h3 class="text-2xl mt-8">What this looks like in practice</h3>
      <ul class="mt-3 list-disc pl-5 text-stone-700 space-y-1">
        <li>A contact form submission automatically creates a CRM entry, sends a welcome email, and notifies your team in Slack</li>
        <li>A new event on your site automatically posts to social media and emails your list</li>
        <li>A grant application draft is generated from a template and routed for review — without anyone touching a file manually</li>
        <li>A donation triggers a thank-you email, updates your donor database, and creates a follow-up task</li>
      </ul>

      <p class="mt-6 text-stone-700">Automations are scoped, priced, and delivered on a project basis.</p>

      <div class="mt-6">
        <Button href="/contact">Book a Discovery Call</Button>
      </div>
    </div>
  </section>

  <section id="growth" class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <SectionHeading title="Growth and Outreach.">
      <p>Reaching more of the people you exist to serve takes more than a good website. It takes a consistent presence, the right messages in the right places, and systems that make it sustainable for your team.</p>
    </SectionHeading>

    <div class="mt-8">
      <h3 class="text-2xl">Digital Marketing Strategy</h3>
      <p class="mt-2 text-stone-700">A clear, realistic plan for growing your presence across the channels that matter most — social media, email, content, and search. Focused on sustainable results, built around what your team can actually maintain.</p>
    </div>

    <div class="mt-8">
      <h3 class="text-2xl">Local Search and AI Visibility</h3>
      <p class="mt-2 text-stone-700">Making sure your organization shows up when people nearby are searching for what you offer — on Google, on maps, and increasingly in AI-generated answers. We optimize your Google Business Profile, local search presence, and site content so that your community finds you first.</p>
    </div>

    <div class="mt-8">
      <h3 class="text-2xl">Community Engagement</h3>
      <p class="mt-2 text-stone-700">Tools and strategies for building genuine relationships with the people you serve — social media management, email list building, event promotion, and community feedback systems that go beyond broadcasting and actually listen.</p>
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-6">
      <Button href="/contact">Book a Discovery Call</Button>
      <a href="mailto:holler@weallrize.ca" class="font-semibold text-brand-red hover:text-ink">holler@weallrize.ca</a>
    </div>
  </section>
</BaseLayout>
