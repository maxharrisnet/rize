---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AnchorNav from '../components/AnchorNav.astro';
import PricingTable from '../components/PricingTable.astro';
import IconList from '../components/IconList.astro';
import Steps from '../components/Steps.astro';

const chipMap = { red: 'bg-brand-red text-white', blue: 'bg-brand-blue text-white', gold: 'bg-brand-gold text-ink' };

const howSteps = [
  { title: 'Discovery call', body: '20 minutes, free, no commitment.' },
  { title: 'Proposal', body: 'Clear scope, clear price, plain language.' },
  { title: 'Build and deliver', body: 'We do the work and keep you informed throughout.' },
  { title: 'Handoff and training', body: 'We walk your team through everything so you can own it.' },
];

const orgServices = [
  {
    title: 'Community and Nonprofit Websites', icon: 'ph:globe-bold', accent: 'red',
    desc: 'A website that tells your story, showcases your programs, connects people to your mission, and makes it easy to donate, register, or get involved. Built on WordPress so your team can update content without a developer.',
    features: [
      'Donation integration — Canada Helps, Stripe, PayPal — including recurring giving',
      'Event listings and program pages with past and upcoming date handling',
      'Volunteer management and contact forms',
      'Email newsletter signup and donor communication tools',
      'Accessible design (WCAG 2.1) and mobile-first build',
    ],
  },
  {
    title: 'Events and Programming Sites', icon: 'ph:ticket-bold', accent: 'blue',
    desc: 'For organizations running regular events, workshops, or community programming. A site that sells tickets, builds your audience, drives attendance, and keeps your community informed.',
    features: [
      'Event listings with ticket integration — Eventbrite, Ticket Tailor',
      'Program and registration pages',
      'Sponsor recognition and gallery sections',
      'Email and social media integration',
    ],
  },
  {
    title: 'Grant Writing Assistance', icon: 'ph:file-text-bold', accent: 'gold',
    desc: 'We help you identify the provincial and federal funding available for digital skills training and AI upskilling — and assist with the application process. Often what makes a funded partnership possible.',
    features: [
      'Funding source identification for your organization type and community',
      'Application support and co-writing',
      'Program design documentation for grant submissions',
      'Reporting templates for funded programs',
    ],
  },
];

const bizServices = [
  {
    title: 'Booking and Appointment Sites', icon: 'ph:calendar-check-bold', accent: 'red',
    desc: 'For service providers who want clients to book online — saving hours of back-and-forth every week and keeping your calendar full without manual coordination.',
    features: [
      'Online booking — Calendly, Acuity, Square Appointments',
      'Service listings and pricing pages',
      'Client intake forms and automated confirmation emails',
      'Team pages and availability management',
    ],
  },
  {
    title: 'Local Business Sites', icon: 'ph:map-pin-bold', accent: 'blue',
    desc: 'For brick-and-mortar businesses and local service providers who want to be found, trusted, and contacted by people in their neighborhood. Strong local and AI search means you show up when it matters.',
    features: [
      'Google Maps and Google Business Profile setup and optimization',
      'Local SEO and AI search optimization — Google, maps, and AI answers',
      'Hours, location, and click-to-call setup',
      'Menu, service listings, and photo galleries',
    ],
  },
  {
    title: 'Creative Portfolio Sites', icon: 'ph:palette-bold', accent: 'gold',
    desc: 'For musicians, photographers, videographers, designers, and other creative professionals who need a home for their work that makes an impression and gets them hired or booked.',
    features: [
      'Gallery and portfolio display',
      'Music and video embeds — Spotify, SoundCloud, Vimeo, YouTube',
      'Press kit and media download pages',
      'Booking and contact integration',
    ],
  },
  {
    title: 'E-Commerce and Online Stores', icon: 'ph:shopping-cart-bold', accent: 'blue',
    desc: 'For businesses and makers ready to sell online — a storefront that is easy to run, easy to buy from, and built to grow with your catalogue.',
    features: [
      'Online store setup — Shopify, WooCommerce, or Squarespace',
      'Product, collection, and inventory management your team can own',
      'Secure checkout, payments, and shipping configuration',
      'Digital products, subscriptions, and local pickup options',
    ],
  },
];

const connect = [
  'CRM systems — HubSpot, Mailchimp — to your website, email, and lead capture',
  'Booking and scheduling tools to your calendar and client communications',
  'Donation and payment platforms to your website and donor follow-up',
  'Social media and email marketing to your content workflow',
  'Internal tools — Slack, Microsoft Teams — to your task and project management',
  'AI tools — Claude, ChatGPT — to your content creation and research workflows',
  "Google Workspace and Microsoft 365 to your team's daily operations",
];
const inPractice = [
  'A contact form submission automatically creates a CRM entry, sends a welcome email, and notifies your team in Slack',
  'A new event on your site automatically posts to social media and emails your list',
  'A grant application draft is generated from a template and routed for review — without anyone touching a file manually',
  'A donation triggers a thank-you email, updates your donor database, and creates a follow-up task',
];

const growth = [
  { title: 'Digital Marketing Strategy', icon: 'ph:megaphone-bold', accent: 'red', desc: 'A clear, realistic plan for growing your presence across the channels that matter most — social media, email, content, and search. Built around what your team can actually maintain.' },
  { title: 'Local Search and AI Visibility', icon: 'ph:magnifying-glass-bold', accent: 'blue', desc: 'Making sure your organization shows up when people nearby search for what you offer — on Google, on maps, and in AI-generated answers. We optimize your profile, local presence, and content so your community finds you first.' },
  { title: 'Community Engagement', icon: 'ph:users-three-bold', accent: 'gold', desc: 'Tools and strategies for building genuine relationships with the people you serve — social media management, email list building, event promotion, and feedback systems that actually listen.' },
];

const orgTiers = [
  { name: 'Starter', price: 'from $750', detail: 'Up to 5 pages.' },
  { name: 'Standard', price: 'from $1,500', detail: 'Up to 10 pages, events or blog section, email integration.' },
  { name: 'Growth', price: 'from $2,500', detail: 'Up to 20 pages, donation system, custom content types, team training.' },
];
const bizTiers = [
  { name: 'Starter', price: 'from $750', detail: 'Up to 5 pages.' },
  { name: 'Standard', price: 'from $1,500', detail: 'Up to 10 pages, blog or booking integration, CRM setup.' },
  { name: 'Growth', price: 'from $2,500', detail: 'Up to 20 pages, custom features, automations, team training.' },
];
const bizAddOns = [
  { name: 'AI-assisted copywriting (up to 5 pages)', price: '$300' },
  { name: 'Brand identity (logo, colors, fonts, usage guide)', price: '$400' },
  { name: 'Bilingual site (English + French or other)', price: 'from $500' },
  { name: 'Accessibility audit and remediation', price: '$350' },
  { name: 'Local SEO and AI visibility package', price: 'from $400' },
  { name: 'Ongoing maintenance and support', price: 'from $150/month' },
];
---
<BaseLayout
  title="Website & Automation Services | Rize Skill Training Vancouver"
  description="Websites, automation systems, and digital marketing for community organizations, nonprofits, small businesses, and entrepreneurs in Vancouver. Clear pricing."
>
  <Hero title="Services that make<br />your organization stronger.">
    <Fragment slot="lead">
      <p>Beyond training, we build websites, automation systems, and digital marketing for community organizations, nonprofits, small businesses, and entrepreneurs across Vancouver and the surrounding area. Professional results, accessible process, clear pricing.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Book a Free Discovery Call</Button>
    </Fragment>
  </Hero>

  <AnchorNav anchors={[
    { label: 'For Organizations', href: '#organizations' },
    { label: 'For Businesses and Entrepreneurs', href: '#businesses' },
    { label: 'Integrations and Automations', href: '#automations' },
    { label: 'Growth and Outreach', href: '#growth' },
  ]} />

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="How it works.">
      <p>Every engagement starts with a free 20-minute discovery call. We learn about your organization, your goals, and your current setup — and give you an honest picture of what would actually help and what it would cost.</p>
    </SectionHeading>
    <Steps steps={howSteps} />
    <div class="mt-10"><Button href="/contact">Book a Free Discovery Call</Button></div>
  </section>

  <section id="organizations" class="container-wide py-16 md:py-24">
    <SectionHeading title="For Organizations.">
      <p>Nonprofits, charities, community groups, and social service agencies have specific needs — donation systems, event management, volunteer coordination, and a presence that communicates mission and builds trust. We build websites and systems designed around those needs, with training included so your team can manage everything independently.</p>
    </SectionHeading>
    <div class="grid gap-6">
      {orgServices.map((s) => (
        <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-10">
          <div class="grid gap-8 md:grid-cols-2 md:items-start">
            <div>
              <div class="flex items-center gap-4">
                <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipMap[s.accent]]}><Icon name={s.icon} /></span>
                <h3 class="text-h3">{s.title}</h3>
              </div>
              <p class="mt-4 text-body-lg text-body-muted">{s.desc}</p>
            </div>
            <div><IconList items={s.features} /></div>
          </div>
        </div>
      ))}
    </div>

    <h3 class="text-h3 mt-14">Pricing</h3>
    <p class="mt-2 text-body text-meta-muted">All projects start with a discovery call. Pricing is based on scope, complexity, and timeline.</p>
    <div class="mt-6"><PricingTable tiers={orgTiers} accent="red" /></div>
    <div class="mt-8"><Button href="/contact">Book a Discovery Call</Button></div>
  </section>

  <section id="businesses" class="container-wide py-16 md:py-24">
    <SectionHeading title="For Businesses and Entrepreneurs.">
      <p>Small businesses, independent service providers, and entrepreneurs need websites that bring the right people to them — and systems that keep operations running without constant manual effort. We build both, with a focus on local search visibility and integrations that actually reduce your workload.</p>
    </SectionHeading>
    <div class="grid gap-6">
      {bizServices.map((s) => (
        <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-10">
          <div class="grid gap-8 md:grid-cols-2 md:items-start">
            <div>
              <div class="flex items-center gap-4">
                <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipMap[s.accent]]}><Icon name={s.icon} /></span>
                <h3 class="text-h3">{s.title}</h3>
              </div>
              <p class="mt-4 text-body-lg text-body-muted">{s.desc}</p>
            </div>
            <div><IconList items={s.features} /></div>
          </div>
        </div>
      ))}
    </div>

    <h3 class="text-h3 mt-14">Pricing</h3>
    <p class="mt-2 text-body text-meta-muted">All projects start with a discovery call. Pricing is based on scope, complexity, and timeline.</p>
    <div class="mt-6"><PricingTable tiers={bizTiers} addOns={bizAddOns} accent="blue" /></div>
    <div class="mt-8"><Button href="/contact">Book a Discovery Call</Button></div>
  </section>

  <section id="automations" class="container-wide py-16 md:py-24">
    <SectionHeading title="Integrations and Automations.">
      <p>The biggest opportunity most organizations are missing is connecting the tools they already use — so information flows automatically, tasks happen without manual triggers, and your team spends more time on the work that matters. Using tools like n8n, Zapier, Claude AI, and Slack, we build integrations that are reliable, maintainable, and yours to own.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-blue text-white text-3xl"><Icon name="ph:plugs-connected-bold" /></span>
          <h3 class="text-h3">What we connect</h3>
        </div>
        <div class="mt-5"><IconList items={connect} /></div>
      </div>
      <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:sparkle-bold" /></span>
          <h3 class="text-h3">What this looks like in practice</h3>
        </div>
        <div class="mt-5"><IconList items={inPractice} /></div>
      </div>
    </div>
    <p class="mt-8 text-body text-body-muted">Automations are scoped, priced, and delivered on a project basis.</p>
    <div class="mt-6"><Button href="/contact">Book a Discovery Call</Button></div>
  </section>

  <section id="growth" class="container-wide py-16 md:py-24">
    <SectionHeading title="Growth and Outreach.">
      <p>Reaching more of the people you exist to serve takes more than a good website. It takes a consistent presence, the right messages in the right places, and systems that make it sustainable for your team.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {growth.map((s) => (
        <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
          <div class="flex items-center gap-4">
            <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipMap[s.accent]]}><Icon name={s.icon} /></span>
            <h3 class="text-h3">{s.title}</h3>
          </div>
          <p class="mt-4 text-body text-body-muted">{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-10 flex flex-wrap items-center gap-6">
      <Button href="/contact">Book a Discovery Call</Button>
      <a href="mailto:holler@weallrize.ca" class="font-bold text-brand-red hover:text-ink">holler@weallrize.ca</a>
    </div>
  </section>
</BaseLayout>
