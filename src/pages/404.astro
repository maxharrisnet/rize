---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout title="Page not found | Rize Skill Training" description="The page you are looking for is not here.">
  <section class="mx-auto max-w-3xl px-4 py-32 text-center">
    <p class="uppercase tracking-widest text-body font-semibold text-ink mb-3">404</p>
    <h1 class="text-5xl md:text-6xl">Page not found.</h1>
    <p class="mt-6 text-lg text-body-muted">The page you are looking for moved or never existed. Let's get you back on track.</p>
    <div class="mt-8 flex justify-center"><Button href="/">Back to home</Button></div>
  </section>
</BaseLayout>
