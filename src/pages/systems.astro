---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AnchorNav from '../components/AnchorNav.astro';
import PricingTable from '../components/PricingTable.astro';
import IconList from '../components/IconList.astro';
import Steps from '../components/Steps.astro';
import Photo from '../components/Photo.astro';
import donationBox from '../assets/images/donation-box.jpg';
import deliOwner from '../assets/images/deli-owner.jpg';
import socialOutreach from '../assets/images/social-outreach.jpg';

const chipMap: Record<string, string> = { red: 'bg-brand-red text-white', ink: 'bg-ink text-cream' };
const tileBg: Record<string, string> = { red: 'bg-brand-red text-white', ink: 'bg-ink text-cream' };
const tileChip: Record<string, string> = { red: 'bg-white text-brand-red', ink: 'bg-brand-red text-white' };

const transformPackages = [
  {
    name: 'Own Your Website',
    icon: 'ph:key-bold',
    accent: 'red',
    promise: 'A professional site your team updates without calling a developer.',
    audience: 'For organizations and businesses that want a real web presence — and full control of it.',
    includes: [
      'A WordPress site designed around your goals, your community, and your voice',
      'Accessible (WCAG 2.1), mobile-first, and built to be found in local and AI search',
      'Hands-on training for your team — editing pages, posting updates, adding events',
      'Full ownership and documentation — your site, your accounts, your keys',
    ],
    vignette:
      'A neighborhood arts nonprofit used to email their web person — and wait — for every event listing and board update. Now the program manager posts events in minutes, the team edits pages themselves, and the site finally keeps up with the work.',
  },
  {
    name: 'Get Your Time Back',
    icon: 'ph:clock-countdown-bold',
    accent: 'ink',
    promise: 'The repetitive work that eats your week, set up to run itself.',
    audience: 'For teams losing hours to follow-up emails, triple-posted updates, and copying information between tools.',
    includes: [
      'A working session to map where the hours actually go',
      'Automation for the repeat work — follow-ups, reminders, posting, data entry',
      'Integrations that connect Slack, HubSpot, Google Workspace, and the tools you already use',
      'Documentation and training so your team owns and adjusts every workflow',
    ],
    vignette:
      'A program coordinator’s Monday used to go to copying weekend registrations into a spreadsheet, posting the same update to three platforms, and answering the same five questions by email. Now registrations file themselves, one update posts everywhere, the website answers the questions — and Monday belongs to the participants.',
  },
  {
    name: 'Reach More People',
    icon: 'ph:broadcast-bold',
    accent: 'red',
    promise: 'Bigger reach with the same team.',
    audience: 'For organizations and businesses ready to grow their audience without growing their workload.',
    includes: [
      'A website chatbot that answers common questions around the clock — in your voice, with your information',
      'Email and social outreach that sounds like you and goes out on schedule',
      'Local search and AI visibility — Google, maps, and AI-generated answers',
      'Feedback, signup, and follow-up systems that help you listen and respond without the busywork',
    ],
    vignette:
      'A family-run studio was answering the same booking questions at 10pm and posting to social media “when there was time” — which meant rarely. Now the chatbot answers instantly, classes are promoted every week without anyone logging in, and new students keep finding them.',
  },
];

const howSteps = [
  { title: 'Discovery call', body: '20 minutes, free, no commitment.' },
  { title: 'Proposal', body: 'Clear scope, clear price, plain language.' },
  { title: 'Build and deliver', body: 'We do the work and keep you informed throughout.' },
  { title: 'Handoff and training', body: 'We walk your team through everything so you can own it.' },
];

const orgServices = [
  {
    title: 'Community and Nonprofit Websites', icon: 'ph:globe-bold', accent: 'red',
    desc: 'A website that tells your story, showcases your programs, connects people to your mission, and makes it easy to donate, register, or get involved. Built on WordPress so your team can update content without a developer.',
    features: [
      'Donation integration — Canada Helps, Stripe, PayPal — including recurring giving',
      'Event listings and program pages with past and upcoming date handling',
      'Volunteer management and contact forms',
      'Email newsletter signup and donor communication tools',
      'Accessible design (WCAG 2.1) and mobile-first build',
    ],
  },
  {
    title: 'Events and Programming Sites', icon: 'ph:ticket-bold', accent: 'ink',
    desc: 'For organizations running regular events, workshops, or community programming. A site that sells tickets, builds your audience, drives attendance, and keeps your community informed.',
    features: [
      'Event listings with ticket integration — Eventbrite, Ticket Tailor',
      'Program and registration pages',
      'Sponsor recognition and gallery sections',
      'Email and social media integration',
    ],
  },
  {
    title: 'Grant Writing Assistance', icon: 'ph:file-text-bold', accent: 'red',
    desc: 'We help you identify the provincial and federal funding available for digital skills training and AI upskilling — and assist with the application process. Often what makes a funded partnership possible.',
    features: [
      'Funding source identification for your organization type and community',
      'Application support and co-writing',
      'Program design documentation for grant submissions',
      'Reporting templates for funded programs',
    ],
  },
];

const bizServices = [
  {
    title: 'Booking and Appointment Sites', icon: 'ph:calendar-check-bold', accent: 'red',
    desc: 'For service providers who want clients to book online — saving hours of back-and-forth every week and keeping your calendar full without manual coordination.',
    features: [
      'Online booking — Calendly, Acuity, Square Appointments',
      'Service listings and pricing pages',
      'Client intake forms and automated confirmation emails',
      'Team pages and availability management',
    ],
  },
  {
    title: 'Local Business Sites', icon: 'ph:map-pin-bold', accent: 'ink',
    desc: 'For brick-and-mortar businesses and local service providers who want to be found, trusted, and contacted by people in their neighborhood. Strong local and AI search means you show up when it matters.',
    features: [
      'Google Maps and Google Business Profile setup and optimization',
      'Local SEO and AI search optimization — Google, maps, and AI answers',
      'Hours, location, and click-to-call setup',
      'Menu, service listings, and photo galleries',
    ],
  },
  {
    title: 'Creative Portfolio Sites', icon: 'ph:palette-bold', accent: 'red',
    desc: 'For musicians, photographers, videographers, designers, and other creative professionals who need a home for their work that makes an impression and gets them hired or booked.',
    features: [
      'Gallery and portfolio display',
      'Music and video embeds — Spotify, SoundCloud, Vimeo, YouTube',
      'Press kit and media download pages',
      'Booking and contact integration',
    ],
  },
  {
    title: 'E-Commerce and Online Stores', icon: 'ph:shopping-cart-bold', accent: 'ink',
    desc: 'For businesses and makers ready to sell online — a storefront that is easy to run, easy to buy from, and built to grow with your catalogue.',
    features: [
      'Online store setup — Shopify, WooCommerce, or Squarespace',
      'Product, collection, and inventory management your team can own',
      'Secure checkout, payments, and shipping configuration',
      'Digital products, subscriptions, and local pickup options',
    ],
  },
];

const connect = [
  'CRM systems — HubSpot, Mailchimp — to your website, email, and lead capture',
  'Booking and scheduling tools to your calendar and client communications',
  'Donation and payment platforms to your website and donor follow-up',
  'Social media and email marketing to your content workflow',
  'Internal tools — Slack, Microsoft Teams — to your task and project management',
  'AI tools — Claude, ChatGPT — to your content creation and research workflows',
  "Google Workspace and Microsoft 365 to your team's daily operations",
];
const inPractice = [
  'A contact form submission automatically creates a CRM entry, sends a welcome email, and notifies your team in Slack',
  'A new event on your site automatically posts to social media and emails your list',
  'A grant application draft is generated from a template and routed for review — without anyone touching a file manually',
  'A donation triggers a thank-you email, updates your donor database, and creates a follow-up task',
];

const growth = [
  { title: 'Digital Marketing Strategy', icon: 'ph:megaphone-bold', accent: 'red', desc: 'A clear, realistic plan for growing your presence across the channels that matter most — social media, email, content, and search. Built around what your team can actually maintain.' },
  { title: 'Local Search and AI Visibility', icon: 'ph:magnifying-glass-bold', accent: 'ink', desc: 'Making sure your organization shows up when people nearby search for what you offer — on Google, on maps, and in AI-generated answers. We optimize your profile, local presence, and content so your community finds you first.' },
  { title: 'Community Engagement', icon: 'ph:users-three-bold', accent: 'red', desc: 'Tools and strategies for building genuine relationships with the people you serve — social media management, email list building, event promotion, and feedback systems that actually listen.' },
];

const packages = [
  {
    name: 'Starter',
    price: 'from $750',
    description: 'A clean, professional presence that gets you found and trusted — fast.',
    features: [
      'Up to 5 pages, mobile-first and accessible (WCAG 2.1)',
      'Contact form and email newsletter signup',
      'Local SEO and Google Business Profile setup',
      'Built on WordPress so your team can edit content',
    ],
    fit: 'New organizations, solo founders, and anyone launching their first real site.',
  },
  {
    name: 'Standard',
    price: 'from $1,500',
    description: 'Room to grow — events, a blog or booking, and the integrations that save you time.',
    features: [
      'Up to 10 pages',
      'Blog, events, or online booking section',
      'Email marketing and CRM integration',
      'Donation or payment setup — Canada Helps, Stripe, PayPal',
      'Enhanced local and AI search visibility',
    ],
    fit: 'Established groups running programs, events, or a steady flow of clients.',
    featured: true,
  },
  {
    name: 'Growth',
    price: 'from $2,500',
    description: 'A tailored site with automations and training so your team fully owns it.',
    features: [
      'Up to 20 pages with custom content types',
      'Donation systems, memberships, or e-commerce',
      'Workflow automations that reduce manual work',
      'Team training and documentation',
      'Priority support through launch',
    ],
    fit: 'Organizations and businesses ready to invest in a system, not just a site.',
  },
];
const addOns = [
  { name: 'AI-assisted copywriting (up to 5 pages)', price: '$300' },
  { name: 'Brand identity (logo, colors, fonts, usage guide)', price: '$400' },
  { name: 'Bilingual site (English + French or other)', price: 'from $500' },
  { name: 'Accessibility audit and remediation', price: '$350' },
  { name: 'Local SEO and AI visibility package', price: 'from $400' },
  { name: 'Ongoing maintenance and support', price: 'from $150/month' },
];
---
<BaseLayout
  title="Websites, AI & Automation Systems | Rize Skill Training Vancouver"
  description="Transformation packages for community organizations, nonprofits, small businesses, and entrepreneurs in Vancouver — websites you own, automation that gives you your time back, and outreach systems that grow your reach."
>
  <Hero title="Less busywork.<br />More of your best work.">
    <Fragment slot="lead">
      <p>There is a gap between what technology makes possible and what busy teams have time to figure out — widest for nonprofits, small businesses, and the communities doing the most with the least. We close it: websites you own, AI put to practical use, and automation that hands your hours back.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Book a Free Discovery Call</Button>
    </Fragment>
  </Hero>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="What we build.">
      <p>Two ways to work with us — outcome-first packages, or a website built around your goals. Either way, we hand over the keys and train your team to own it. Pricing, integrations, and growth support live further down the page.</p>
    </SectionHeading>

    <div class="grid gap-6 md:grid-cols-2">
      <a href="#packages" class="flex h-full flex-col rounded-[14px] border-2 border-ink bg-ink p-8 text-cream transition-transform hover:-translate-y-1 md:p-10">
        <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-4xl"><Icon name="ph:stack-bold" /></span>
        <h3 class="mt-6 text-h2">Packages</h3>
        <p class="mt-3 flex-1 text-body-lg">Three transformation packages — own your website, get your time back, reach more people.</p>
        <p class="mt-4 text-body font-bold">Build + practical AI + training &middot; scoped after a free call</p>
        <span class="mt-6 font-bold uppercase tracking-[0.08em]">See packages &darr;</span>
      </a>
      <a href="#organizations" class="flex h-full flex-col rounded-[14px] border-2 border-ink bg-white p-8 text-ink transition-transform hover:-translate-y-1 md:p-10">
        <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-4xl"><Icon name="ph:globe-bold" /></span>
        <h3 class="mt-6 text-h2">Websites</h3>
        <p class="mt-3 flex-1 text-body-lg text-body-muted">Purpose-built sites for organizations, businesses, and entrepreneurs — updated by your team, not a developer.</p>
        <p class="mt-4 text-body font-bold text-brand-red">From $750 &middot; WordPress &middot; accessible (WCAG 2.1)</p>
        <span class="mt-6 font-bold uppercase tracking-[0.08em]">See websites &darr;</span>
      </a>
    </div>

    <div class="mt-6 grid gap-6 md:grid-cols-3">
      <a href="#pricing" class="h-full rounded-[14px] border-2 border-ink bg-white p-6 transition-transform hover:-translate-y-1">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:tag-bold" /></span>
          <h3 class="text-h3">Website pricing</h3>
        </div>
        <p class="mt-4 text-body text-body-muted">Three clear tiers and add-ons, priced in plain language.</p>
      </a>
      <a href="#automations" class="h-full rounded-[14px] border-2 border-ink bg-white p-6 transition-transform hover:-translate-y-1">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-ink text-cream text-3xl"><Icon name="ph:plugs-connected-bold" /></span>
          <h3 class="text-h3">Integrations and automations</h3>
        </div>
        <p class="mt-4 text-body text-body-muted">Connect the tools you already use so the repeat work runs itself.</p>
      </a>
      <a href="#growth" class="h-full rounded-[14px] border-2 border-ink bg-white p-6 transition-transform hover:-translate-y-1">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:megaphone-bold" /></span>
          <h3 class="text-h3">Growth and outreach</h3>
        </div>
        <p class="mt-4 text-body text-body-muted">Marketing, local and AI search visibility, and community engagement.</p>
      </a>
    </div>

    <div class="mt-6 rounded-[14px] border-2 border-ink bg-white p-8 md:flex md:items-center md:justify-between md:gap-8">
      <div class="max-w-2xl">
        <h3 class="text-h3">Every project starts with a free discovery call.</h3>
        <p class="mt-3 text-body text-body-muted">Twenty minutes, no commitment. We learn about your goals and your current setup — and give you an honest picture of what would actually help and what it would cost.</p>
      </div>
      <div class="mt-6 shrink-0 md:mt-0"><Button href="/contact">Book a Free Discovery Call</Button></div>
    </div>
  </section>

  <AnchorNav anchors={[
    { label: 'Packages', href: '#packages' },
    { label: 'Websites', href: '#organizations' },
    { label: 'Website Pricing', href: '#pricing' },
    { label: 'Integrations and Automations', href: '#automations' },
    { label: 'Growth and Outreach', href: '#growth' },
  ]} />

  <section id="packages" class="container-wide py-16 md:py-24">
    <SectionHeading title="Start with the change you need.">
      <p>Most teams do not need more technology. They need the right technology, connected, doing the boring parts on its own. Each package below bundles the build, the practical AI, the integrations, and the training into one clear outcome — and every one is delivered so your team owns it, not so you stay dependent on us.</p>
      <p>The short stories in each package are examples of what these systems look like in practice. And because no two organizations start from the same place, packages are scoped and priced after a free discovery call — in plain language, with no surprises.</p>
    </SectionHeading>
    <div class="grid gap-10">
      {transformPackages.map((p) => (
        <div class="grid gap-6 md:grid-cols-3">
          <div class:list={["flex flex-col rounded-[14px] border-2 border-ink p-6 md:p-8", tileBg[p.accent]]}>
            <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", tileChip[p.accent]]}><Icon name={p.icon} /></span>
            <h3 class="mt-6 text-h3">{p.name}</h3>
            <p class="mt-3 text-body-lg font-bold">{p.promise}</p>
            <p class="mt-2 flex-1 text-body">{p.audience}</p>
            <a href="/contact" class="mt-6 font-bold uppercase tracking-[0.08em]">Book a free call &rarr;</a>
          </div>
          <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
            <p class="text-body font-bold uppercase tracking-[0.04em] text-ink">What's included</p>
            <div class="mt-4"><IconList items={p.includes} /></div>
          </div>
          <div class="rounded-[14px] border-2 border-ink bg-cream p-6 md:p-8">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-ink text-cream text-3xl"><Icon name="ph:quotes-bold" /></span>
            <p class="mt-6 text-body font-bold uppercase tracking-[0.04em] text-ink">What this looks like</p>
            <p class="mt-3 text-body text-ink">{p.vignette}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-10"><Button href="/contact">Book a Free Discovery Call</Button></div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="How it works.">
      <p>Every engagement starts with a free 20-minute discovery call. We learn about your organization, your goals, and your current setup — and give you an honest picture of what would actually help and what it would cost.</p>
    </SectionHeading>
    <Steps steps={howSteps} />
    <div class="mt-10"><Button href="/contact">Book a Free Discovery Call</Button></div>
  </section>

  <section id="organizations" class="container-wide py-16 md:py-24">
    <div class="mb-10 grid gap-10 md:grid-cols-2 md:items-center">
      <SectionHeading title="For Organizations.">
        <p>Nonprofits, charities, community groups, and social service agencies have specific needs — donation systems, event management, volunteer coordination, and a presence that communicates mission and builds trust. We build websites and systems designed around those needs, with training included so your team can manage everything independently.</p>
      </SectionHeading>
      <Photo
        src={donationBox}
        alt="A smiling nonprofit volunteer holding a donation box"
        class="aspect-[4/3]"
      />
    </div>
    <div class="grid gap-6">
      {orgServices.map((s) => (
        <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-10">
          <div class="grid gap-8 md:grid-cols-2 md:items-start">
            <div>
              <div class="flex items-center gap-4">
                <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipMap[s.accent]]}><Icon name={s.icon} /></span>
                <h3 class="text-h3">{s.title}</h3>
              </div>
              <p class="mt-4 text-body-lg text-body-muted">{s.desc}</p>
            </div>
            <div><IconList items={s.features} /></div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <Button href="/contact">Book a Discovery Call</Button>
      <Button href="#pricing" variant="secondary">See Website Pricing</Button>
    </div>
  </section>

  <section id="businesses" class="container-wide py-16 md:py-24">
    <div class="mb-10 grid gap-10 md:grid-cols-2 md:items-center">
      <SectionHeading title="For Businesses and Entrepreneurs.">
        <p>Small businesses, independent service providers, and entrepreneurs need websites that bring the right people to them — and systems that keep operations running without constant manual effort. We build both, with a focus on local search visibility and integrations that actually reduce your workload.</p>
      </SectionHeading>
      <Photo
        src={deliOwner}
        alt="A shop owner smiling behind the counter of his specialty food store"
        class="aspect-[4/3]"
      />
    </div>
    <div class="grid gap-6">
      {bizServices.map((s) => (
        <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-10">
          <div class="grid gap-8 md:grid-cols-2 md:items-start">
            <div>
              <div class="flex items-center gap-4">
                <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipMap[s.accent]]}><Icon name={s.icon} /></span>
                <h3 class="text-h3">{s.title}</h3>
              </div>
              <p class="mt-4 text-body-lg text-body-muted">{s.desc}</p>
            </div>
            <div><IconList items={s.features} /></div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <Button href="/contact">Book a Discovery Call</Button>
      <Button href="#pricing" variant="secondary">See Website Pricing</Button>
    </div>
  </section>

  <section id="pricing" class="container-wide py-16 md:py-24">
    <SectionHeading title="Website pricing.">
      <p>One clear set of website packages for organizations and businesses alike. Every project starts with a free discovery call — final pricing depends on scope, complexity, and timeline, and these are the starting point.</p>
    </SectionHeading>
    <PricingTable tiers={packages} addOns={addOns} />
    <div class="mt-10"><Button href="/contact">Book a Free Discovery Call</Button></div>
  </section>

  <section id="automations" class="container-wide py-16 md:py-24">
    <SectionHeading title="Integrations and Automations.">
      <p>The biggest opportunity most organizations are missing is connecting the tools they already use — so information flows automatically, tasks happen without manual triggers, and your team spends more time on the work that matters. Using tools like n8n, Zapier, Claude AI, and Slack, we build integrations that are reliable, maintainable, and yours to own.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="h-full rounded-[14px] border-2 border-ink bg-ink p-6 text-cream md:p-8">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:plugs-connected-bold" /></span>
          <h3 class="text-h3">What we connect</h3>
        </div>
        <div class="mt-5"><IconList items={connect} onDark /></div>
      </div>
      <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
        <div class="flex items-center gap-4">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:sparkle-bold" /></span>
          <h3 class="text-h3">What this looks like in practice</h3>
        </div>
        <div class="mt-5"><IconList items={inPractice} /></div>
      </div>
    </div>
    <p class="mt-8 text-body text-body-muted">Automations are scoped, priced, and delivered on a project basis.</p>
    <div class="mt-6"><Button href="/contact">Book a Discovery Call</Button></div>
  </section>

  <section id="growth" class="container-wide py-16 md:py-24">
    <div class="mb-10 grid gap-10 md:grid-cols-2 md:items-center">
      <SectionHeading title="Growth and Outreach.">
        <p>Reaching more of the people you exist to serve takes more than a good website. It takes a consistent presence, the right messages in the right places, and systems that make it sustainable for your team.</p>
      </SectionHeading>
      <Photo
        src={socialOutreach}
        alt="Hands holding two phones with social media reactions floating around them"
        class="aspect-[4/3]"
      />
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {growth.map((s) => (
        <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
          <div class="flex items-center gap-4">
            <span class:list={["flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-3xl", chipMap[s.accent]]}><Icon name={s.icon} /></span>
            <h3 class="text-h3">{s.title}</h3>
          </div>
          <p class="mt-4 text-body text-body-muted">{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-10 flex flex-wrap items-center gap-6">
      <Button href="/contact">Book a Discovery Call</Button>
      <a href="mailto:holler@weallrize.ca" class="font-bold text-ink underline decoration-brand-red decoration-2 underline-offset-4 hover:decoration-ink">holler@weallrize.ca</a>
    </div>
  </section>
</BaseLayout>
