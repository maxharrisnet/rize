---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AnchorNav from '../components/AnchorNav.astro';
import IconList from '../components/IconList.astro';
import Photo from '../components/Photo.astro';
import workshopParticipants from '../assets/images/workshop-participants.jpg';

const workshops = await getCollection('workshops');
const courses = await getCollection('courses');

type Entry = {
  kind: 'workshop' | 'course';
  href: string;
  title: string;
  tagline: string;
  summary: string;
  whoFor: string[];
  outcomes: string[];
  topics?: string[];
  format?: string;
};

const bySlug = new Map<string, Entry>();
for (const w of workshops) {
  bySlug.set(w.id, {
    kind: 'workshop', href: `/workshops/${w.id}`,
    title: w.data.title, tagline: w.data.tagline, summary: w.data.summary,
    whoFor: w.data.whoFor, outcomes: w.data.outcomes, format: w.data.format,
  });
}
for (const c of courses) {
  bySlug.set(c.id, {
    kind: 'course', href: `/courses/${c.id}`,
    title: c.data.title, tagline: c.data.tagline, summary: c.data.summary,
    whoFor: c.data.whoFor, outcomes: c.data.outcomes, topics: c.data.topics,
  });
}
const pick = (slugs: string[]) => slugs.map((s) => bySlug.get(s)).filter(Boolean) as Entry[];

const community = pick(['digital-confidence', 'stay-safe-online', 'organizations-that-move-people']);
const career = pick(['future-proof-your-career']);
const creative = pick(['creative-work-amplified']);
---
<BaseLayout
  title="Learning | Workshops & Courses for Community, Career & Creative"
  description="Workshops and courses organized around Community, Career, and Creative learning paths. Delivered across Vancouver and the surrounding area, for all skill levels."
>
  <Hero title="Programs built around<br />real outcomes.">
    <Fragment slot="lead">
      <p>Workshops and courses for people ready to build real skills with technology — and use those skills to do more of what they care about. Delivered across Vancouver and the surrounding area, with formats for community partners, organizations, and public learners. Accommodating all skill levels.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="#community">Explore Community</Button>
      <Button href="#career" variant="secondary">Explore Career</Button>
      <Button href="#creative" variant="ghost">Explore Creative</Button>
    </Fragment>
  </Hero>

  <AnchorNav anchors={[
    { label: 'How Learning Works', href: '#how-learning-works' },
    { label: 'Community', href: '#community' },
    { label: 'Career', href: '#career' },
    { label: 'Creative', href: '#creative' },
  ]} />

  <section id="how-learning-works" class="container-wide py-16 md:py-24">
    <SectionHeading title="How learning works." />
    <div class="grid gap-6 md:grid-cols-2">
      <div class="flex h-full flex-col rounded-[14px] border-2 border-ink bg-ink p-8 text-cream md:p-10">
        <span class="inline-block w-fit rounded-pill bg-cream px-4 py-1 text-meta font-bold uppercase tracking-[0.04em] text-ink">Workshops</span>
        <p class="mt-5 flex-1 text-body-lg">Single sessions or short series running 90 minutes to half a day. Practical and focused, designed to deliver immediately useful skills. Available through community partnerships and on a public schedule.</p>
      </div>
      <div class="flex h-full flex-col rounded-[14px] border-2 border-ink bg-brand-gold p-8 text-ink md:p-10">
        <span class="inline-block w-fit rounded-pill bg-ink px-4 py-1 text-meta font-bold uppercase tracking-[0.04em] text-cream">Courses</span>
        <p class="mt-5 flex-1 text-body-lg">Multi-session programs running 4 to 6 hours total, designed to build something functional by the end — a workflow, a digital presence, a grant-writing system, or a marketing strategy. Delivered through organizational partnerships.</p>
      </div>
    </div>

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
        <h3 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Delivery options</h3>
        <div class="mt-5"><IconList items={[
          'Partnership delivery — we come to your organization, your space, your community.',
          'Public schedule — open sessions anyone can register for.',
          'Custom engagements — tailored programs for specific groups, industries, or cohorts.',
        ]} /></div>
      </div>
      <div class="flex flex-col justify-between rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
        <div>
          <h3 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Funded partnerships</h3>
          <p class="mt-4 text-body text-body-muted">Provincial and federal funding is available for many of these programs right now, particularly for digital skills and AI upskilling for specific communities. We can help identify what applies and work through the process alongside you.</p>
        </div>
        <div class="mt-6"><Button href="/partnerships">Explore Funded Partnerships</Button></div>
      </div>
    </div>
  </section>

  <section id="community" class="container-wide scroll-mt-24 py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <SectionHeading eyebrow="Community" title="Community programs.">
        <p>Technology should feel useful, understandable, and within reach. This section is for people and organizations that want more confidence, more safety, and more capacity in everyday digital life.</p>
      </SectionHeading>
      <Photo
        src={workshopParticipants}
        alt="Community workshop participants following along on laptops in a bright space"
        class="aspect-[4/3]"
        loading="eager"
      />
    </div>
    <div class="mt-10 space-y-6">
      {community.map((p) => (
        <article class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
          <span class:list={["inline-block rounded-pill px-4 py-1 text-meta font-bold uppercase tracking-[0.04em]", p.kind === 'course' ? 'bg-brand-gold text-ink' : 'bg-ink text-cream']}>{p.kind === 'course' ? 'Course' : 'Workshop'}</span>
          <h3 class="mt-4 text-h3"><a href={p.href} class="hover:text-brand-red">{p.title}</a></h3>
          <p class="mt-3 max-w-3xl text-body text-body-muted">{p.tagline} {p.summary}</p>
          {p.topics && (
            <div class="mt-6 rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Topics covered</h4>
              <div class="mt-4"><IconList items={p.topics} /></div>
            </div>
          )}
          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            <div class="rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Good fit for</h4>
              <div class="mt-4"><IconList items={p.whoFor} /></div>
            </div>
            <div class="rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">What you'll walk away with</h4>
              <div class="mt-4"><IconList items={p.outcomes} /></div>
            </div>
          </div>
          <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
            <a href={p.href} class="font-bold uppercase tracking-[0.08em] text-brand-red hover:text-ink">View full details &rarr;</a>
            {p.format && <p class="text-meta font-bold uppercase tracking-[0.04em] text-meta-muted">{p.format}</p>}
          </div>
        </article>
      ))}
    </div>
    <div class="mt-8"><Button href="/partnerships">Bring a Community Program to Your Organization</Button></div>
  </section>

  <section id="career" class="container-wide scroll-mt-24 py-16 md:py-24">
    <SectionHeading eyebrow="Career" title="Career programs.">
      <p>This section stays focused and learning-centered. It is for people who want to build a stronger professional presence, understand how AI is changing work, and move forward with confidence.</p>
    </SectionHeading>
    <div class="space-y-6">
      {career.map((p) => (
        <article class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
          <span class="inline-block rounded-pill bg-ink px-4 py-1 text-meta font-bold uppercase tracking-[0.04em] text-cream">Workshop</span>
          <h3 class="mt-4 text-h3"><a href={p.href} class="hover:text-brand-red">{p.title}</a></h3>
          <p class="mt-3 max-w-3xl text-body text-body-muted">{p.tagline} {p.summary}</p>
          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            <div class="rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Good fit for</h4>
              <div class="mt-4"><IconList items={p.whoFor} /></div>
            </div>
            <div class="rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">What you'll walk away with</h4>
              <div class="mt-4"><IconList items={p.outcomes} /></div>
            </div>
          </div>
          <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
            <a href={p.href} class="font-bold uppercase tracking-[0.08em] text-brand-red hover:text-ink">View full details &rarr;</a>
            {p.format && <p class="text-meta font-bold uppercase tracking-[0.04em] text-meta-muted">{p.format}</p>}
          </div>
        </article>
      ))}
      <div class="rounded-[14px] border-2 border-ink bg-cream p-6 md:p-8">
        <h3 class="text-h3">Career-ready custom sessions</h3>
        <p class="mt-3 max-w-3xl text-body text-body-muted">For employment centers, workforce partners, youth programs, settlement organizations, and other groups that want modular sessions tailored to their audience and goals.</p>
      </div>
    </div>
    <div class="mt-8"><Button href="/book">Talk to Us About a Career Program</Button></div>
  </section>

  <section id="creative" class="container-wide scroll-mt-24 py-16 md:py-24">
    <SectionHeading eyebrow="Creative" title="Creative programs.">
      <p>Creative work deserves tools that support visibility, sustainability, and momentum. This section is for artists and creative professionals who want to build stronger systems around their work.</p>
    </SectionHeading>
    <div class="space-y-6">
      {creative.map((p) => (
        <article class="rounded-[14px] border-2 border-ink bg-white p-6 md:p-8">
          <span class="inline-block rounded-pill bg-brand-gold px-4 py-1 text-meta font-bold uppercase tracking-[0.04em] text-ink">Course</span>
          <h3 class="mt-4 text-h3"><a href={p.href} class="hover:text-brand-red">{p.title}</a></h3>
          <p class="mt-3 max-w-3xl text-body text-body-muted">{p.tagline} {p.summary}</p>
          {p.topics && (
            <div class="mt-6 rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Topics covered</h4>
              <div class="mt-4"><IconList items={p.topics} /></div>
            </div>
          )}
          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            <div class="rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">Good fit for</h4>
              <div class="mt-4"><IconList items={p.whoFor} /></div>
            </div>
            <div class="rounded-[14px] bg-cream p-6">
              <h4 class="text-eyebrow font-bold uppercase tracking-[0.14em] text-brand-red">What you'll walk away with</h4>
              <div class="mt-4"><IconList items={p.outcomes} /></div>
            </div>
          </div>
          <div class="mt-6">
            <a href={p.href} class="font-bold uppercase tracking-[0.08em] text-brand-red hover:text-ink">View full details &rarr;</a>
          </div>
        </article>
      ))}
      <div class="rounded-[14px] border-2 border-ink bg-cream p-6 md:p-8">
        <h3 class="text-h3">Future creative offerings</h3>
        <p class="mt-3 max-w-3xl text-body text-body-muted">More creative workshops and sector-specific sessions are in development. If you have a particular format or audience in mind, reach out and we can shape something custom.</p>
      </div>
    </div>
    <div class="mt-8"><Button href="/book">Talk to Us About a Creative Program</Button></div>
  </section>

  <section class="bg-ink text-cream">
    <div class="container-wide py-20 text-center">
      <h2 class="text-h2 mb-6 text-brand-gold">Looking for something else?</h2>
      <div class="text-body-lg max-w-3xl mx-auto mb-8 space-y-4">
        <p>If these workshops and courses are not quite the right fit, there is more. We offer one-on-one tutoring and mentorship for individuals who want personalized support, small group instruction for specific topics, and team training for organizations with particular needs. We can also go deeper on more technical topics — development, systems, and tools — for people who are ready for that level.</p>
        <p>More workshops are in development across additional topics and industries. If you have something specific in mind, reach out. The answer is probably yes.</p>
        <p><a href="mailto:holler@weallrize.ca" class="underline hover:no-underline">holler@weallrize.ca</a></p>
      </div>
      <div class="flex flex-wrap gap-4 justify-center">
        <Button href="/book">Get in Touch</Button>
      </div>
    </div>
  </section>
</BaseLayout>
