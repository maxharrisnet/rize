---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PathNav from '../components/PathNav.astro';
import CTASection from '../components/CTASection.astro';
import ProgramDrawer from '../components/ProgramDrawer.astro';
import Photo from '../components/Photo.astro';
import workshopParticipants from '../assets/images/workshop-participants.jpg';
import courseComputerLab from '../assets/images/course-computer-lab.jpg';

const workshops = (await getCollection('workshops')).sort((a, b) => a.data.order - b.data.order);
const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);

type Accent = 'red' | 'blue' | 'gold';
const paths: { id: 'everyday-life' | 'career' | 'entrepreneurship' | 'creative-work'; title: string; accent: Accent; description: string }[] = [
  {
    id: 'everyday-life',
    title: 'Everyday Life',
    accent: 'red',
    description: 'Programs in this path help people use everyday technology with more confidence, more safety, and more independence.',
  },
  {
    id: 'career',
    title: 'Career',
    accent: 'blue',
    description: 'Programs in this path help people strengthen their professional presence, improve job readiness, and use modern tools more effectively at work.',
  },
  {
    id: 'entrepreneurship',
    title: 'Entrepreneurship',
    accent: 'blue',
    description: 'Programs in this path are for people building a business, freelance practice, solo operation, or independent service.',
  },
  {
    id: 'creative-work',
    title: 'Creative Work',
    accent: 'gold',
    description: 'Programs in this path are designed for artists, musicians, writers, filmmakers, designers, and other creative professionals building audience, releasing work, and developing a more sustainable practice.',
  },
];

const pathNavItems = paths.map((p) => ({
  label: p.title,
  href: `#${p.id}`,
  count: workshops.filter((w) => w.data.path === p.id).length + courses.filter((c) => c.data.path === p.id).length,
}));
---
<BaseLayout
  title="Workshops & Courses | Digital Skills & AI Training in Vancouver"
  description="Workshops and courses across four learning paths — Everyday Life, Career, Entrepreneurship, and Creative Work. Delivered in Vancouver and the Greater Vancouver area."
>
  <Hero title="Programs built around<br />real outcomes.">
    <Fragment slot="lead">
      <p>Workshops and courses for people, organizations, and communities ready to build practical skills with technology — and use those skills to do more of what matters to them. Delivered in Vancouver and the Greater Vancouver area, with selected programs also available through video.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="#paths">Explore Learning Paths</Button>
      <Button href="/partnerships" variant="secondary">Explore Funded Partnerships</Button>
    </Fragment>
  </Hero>

  <section class="container-wide py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <SectionHeading title="Learning that meets people where they are.">
        <p>Rize Skill Training offers practical learning experiences for people building confidence with everyday technology, strengthening their work and career skills, growing a business, or supporting a creative practice. Every program is designed around real use, real goals, and the actual comfort level people bring into the room.</p>
        <p>We do not expect every group to start from the same place. We work with organizations and internal teams to shape delivery around the audience, the timeline, the learning level, and the community context so participants can engage in a way that feels useful, accessible, and grounded.</p>
      </SectionHeading>
      <Photo
        src={workshopParticipants}
        alt="Workshop participants smiling and following along on laptops in a bright community space"
        class="aspect-[4/3]"
        loading="eager"
      />
    </div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="Workshops and courses, shaped around the people in the room." />

    <div class="grid gap-6 md:grid-cols-2">
      <div class="flex h-full flex-col rounded-[14px] border-2 border-ink bg-ink p-8 text-cream md:p-10">
        <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-4xl"><Icon name="ph:chalkboard-teacher-bold" /></span>
        <h3 class="mt-6 text-h2">Workshops</h3>
        <p class="mt-3 flex-1 text-body-lg">Single sessions or short series running from 90 minutes to half a day. Practical, focused, and designed to give people skills they can use right away.</p>
        <p class="mt-4 text-body font-bold">90 min–half day &middot; single session or short series &middot; in person or online</p>
      </div>
      <div class="flex h-full flex-col rounded-[14px] border-2 border-ink bg-white p-8 text-ink md:p-10">
        <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-4xl"><Icon name="ph:graduation-cap-bold" /></span>
        <h3 class="mt-6 text-h2">Courses</h3>
        <p class="mt-3 flex-1 text-body-lg text-body-muted">Multi-session learning experiences for groups ready to go deeper — building confidence over time and leaving with a clearer way to use technology in work or everyday life.</p>
        <p class="mt-4 text-body font-bold text-brand-red">Multi-session &middot; delivered in partnership &middot; selected courses through video</p>
      </div>
    </div>
  </section>

  <section id="paths" class="container-wide pt-16 md:pt-24">
    <SectionHeading align="center" title="Learning paths.">
      <p>Every program belongs to one of four learning paths. Courses are multi-session experiences for groups ready to go deeper; workshops are single sessions or short series. Open any program for who it fits best and what participants walk away with.</p>
    </SectionHeading>
  </section>

  <PathNav items={pathNavItems} />

  <section class="container-wide pb-16 md:pb-24">
    {paths.map((path, i) => (
      <div id={path.id} class:list={["scroll-mt-36", i === 0 ? "mt-12 md:mt-16" : "mt-20 md:mt-28"]}>
        <h3 class="text-h1">{path.title}</h3>
        <p class="mt-4 max-w-3xl text-body-lg text-body-muted">{path.description}</p>
        <div class="mt-8 space-y-5">
          {courses
            .filter((c) => c.data.path === path.id)
            .map((c) => (
              <ProgramDrawer
                kind="course"
                title={c.data.title}
                tagline={c.data.tagline}
                summary={c.data.summary}
                whoFor={c.data.whoFor}
                outcomes={c.data.outcomes}
                href={`/courses/${c.id}`}
                ctaLabel="View Course Details"
                accent={path.accent}
              />
            ))}
          {workshops
            .filter((w) => w.data.path === path.id)
            .map((w) => (
              <ProgramDrawer
                kind="workshop"
                title={w.data.title}
                tagline={w.data.tagline}
                summary={w.data.summary}
                whoFor={w.data.whoFor}
                outcomes={w.data.outcomes}
                format={w.data.format}
                href={`/workshops/${w.id}`}
                ctaLabel="View Workshop Details"
                accent={path.accent}
              />
            ))}
        </div>
      </div>
    ))}

    <p class="mt-16 text-body text-body-muted">Additional workshops and courses are in development. <a href="/contact" class="font-bold text-ink underline decoration-brand-red decoration-2 underline-offset-4 hover:decoration-ink">Talk to us about a custom program</a> for your community or sector.</p>
  </section>

  <section class="container-wide pb-16 md:pb-24">
    <div class="rounded-[14px] border-2 border-ink bg-white">
      <div class="grid md:grid-cols-2 md:items-stretch">
        <div class="p-8 md:p-12">
          <h3 class="text-h2">Delivered in partnership</h3>
          <p class="mt-6 text-body text-ink">The strongest version of this work happens in partnership with organizations that already have trusted relationships with the people they serve. We come to your organization, your space, and your community — and selected workshops also run on an open public schedule.</p>
          <p class="mt-4 text-body text-ink">Every partnership starts with a conversation about who the program is for, what they need, and what success looks like in your context. Together with your internal team, we shape the format, pacing, accessibility, cultural safety, and learning level so the program fits the people it is meant to serve.</p>
          <p class="mt-4 text-body text-ink">Need support with funding, planning, or program design? We work with community organizations, nonprofits, Indigenous-led groups, Black-led organizations, libraries, employment programs, and other trusted partners — and where relevant, we help identify funding pathways and shape a program package that fits both community need and available support.</p>
          <div class="mt-8"><Button href="/partnerships">Explore Funded Partnerships</Button></div>
        </div>
        <div class="p-8 pt-0 md:p-12 md:pl-0 md:pt-12">
          <Photo
            src={courseComputerLab}
            alt="Two women wearing headsets learning together at computers"
            class="aspect-[4/3] h-full md:aspect-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <CTASection title="Not sure where to start?">
    <Fragment slot="body">
      <p>If you already know which workshop or course you want, we can start there. If you want help choosing the right fit for your audience, team, or community, we can shape that together.</p>
      <p class="mt-4"><a href="mailto:holler@weallrize.ca" class="underline hover:no-underline">holler@weallrize.ca</a></p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Get in Touch</Button>
      <Button href="/partnerships" variant="secondary">Explore Funded Partnerships</Button>
    </Fragment>
  </CTASection>
</BaseLayout>
