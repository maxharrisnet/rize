---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Steps from '../components/Steps.astro';
import CTASection from '../components/CTASection.astro';
import { fundingGroups } from '../data/funding';

const model = [
  {
    title: 'You bring the community',
    body: 'The people, the space, and the trust you have already built.',
    icon: 'ph:users-three-bold',
    bg: 'bg-brand-red',
    text: 'text-white',
    chip: 'bg-white text-brand-red',
  },
  {
    title: 'We bring the program',
    body: 'Curriculum, facilitation, and materials, delivered by us alongside your team.',
    icon: 'ph:chalkboard-teacher-bold',
    bg: 'bg-brand-blue',
    text: 'text-white',
    chip: 'bg-white text-brand-blue',
  },
  {
    title: 'We bring the funding strategy',
    body: 'We identify the grants that apply to your organization and help you apply.',
    icon: 'ph:hand-coins-bold',
    bg: 'bg-brand-gold',
    text: 'text-ink',
    chip: 'bg-ink text-brand-gold',
  },
];

const team = [
  {
    title: 'We build with your team',
    body: 'Your community leads, cultural workers, and program staff shape the content, so it reflects how your community actually works.',
    icon: 'ph:handshake-bold',
  },
  {
    title: 'We tailor everything to the group',
    body: 'Content, examples, pace, and language adapt to each community — cultural, linguistic, and accessibility needs included.',
    icon: 'ph:sliders-horizontal-bold',
  },
  {
    title: 'Your mission comes first',
    body: 'The technology serves your goals and your values. Your goals never bend to fit the tool.',
    icon: 'ph:compass-bold',
  },
  {
    title: 'People before technology',
    body: 'We start with who is in the room and what matters to them. The tools come after.',
    icon: 'ph:heart-bold',
  },
];

const steps = [
  {
    title: 'Reach out',
    body: 'Tell us who you are, who your community is, and what you are hoping to achieve. A short conversation is all it takes to get started.',
  },
  {
    title: 'We design together',
    body: 'We work with you to identify the right program, confirm the format, and — where applicable — identify funding sources that can cover the cost.',
  },
  {
    title: 'We show up and deliver',
    body: 'We handle the curriculum, the facilitation, and the materials. Your community shows up and leaves with real skills and real confidence.',
  },
  {
    title: 'You keep the momentum',
    body: 'Every program comes with resources participants can reference independently. For organizations, we are available for follow-up support, ongoing training, or next-step programs.',
  },
];

const chipClass = {
  red: 'bg-brand-red text-white',
  blue: 'bg-brand-blue text-white',
  gold: 'bg-brand-gold text-ink',
};

const orgTypes = [
  'Community organizations',
  'Nonprofits and charities',
  'Indigenous-led groups',
  'Black community organizations',
  'Libraries',
  'Employment centers',
  'Social service agencies',
];
---
<BaseLayout
  title="Funded Partnerships | Technology Training for Nonprofits in Vancouver"
  description="Provincial, federal, and corporate funding is available now for digital skills and AI upskilling. We help Vancouver community organizations find funding, apply, and bring workshops and courses to the people they serve."
>
  <Hero title="Bring funded programs<br />to your community.">
    <Fragment slot="lead">
      <p>Provincial, federal, and corporate programs are actively funding digital-skills and AI training right now. We help you find the funding that fits, handle the application, and deliver a workshop or course your community genuinely benefits from — often at little or no cost to you.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Get in Touch</Button>
    </Fragment>
  </Hero>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="How funded partnerships work.">
      <p>You bring the community. We bring the program, the facilitation, and the funding strategy — so the cost lands on a grant, not on your budget.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-3">
      {model.map((m) => (
        <div class:list={["h-full rounded-[14px] border-2 border-ink p-6", m.bg, m.text]}>
          <span class:list={["inline-flex h-12 w-12 items-center justify-center rounded-full text-2xl", m.chip]}>
            <Icon name={m.icon} />
          </span>
          <h3 class="text-h3 mt-4">{m.title}</h3>
          <p class="mt-3 text-body">{m.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="Funding for the communities you serve.">
      <p>Different communities have different funding available. Here is where the support tends to be strongest — we help you find the specific program that fits and apply for it.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {fundingGroups.map((g) => (
        <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6">
          <span class:list={["inline-flex h-12 w-12 items-center justify-center rounded-full text-2xl", chipClass[g.accent]]}>
            <Icon name={g.icon} />
          </span>
          <h3 class="text-h3 mt-4">{g.title}</h3>
          <p class="mt-3 text-body text-body-muted">{g.body}</p>
        </div>
      ))}
    </div>
    <p class="mt-8 max-w-3xl text-body-lg font-bold text-brand-red">Programs change constantly. We track what is currently open and match it to your community — you do not have to keep up with it yourself.</p>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="Built around your team and your community.">
      <p>We do not arrive with a fixed curriculum and hope it lands. We work alongside your staff — including the people who know your community best — so every session fits the people in the room.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2">
      {team.map((t) => (
        <div class="h-full rounded-[14px] border-2 border-ink bg-white p-6">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-blue text-white text-2xl">
            <Icon name={t.icon} />
          </span>
          <h3 class="text-h3 mt-4">{t.title}</h3>
          <p class="mt-3 text-body text-body-muted">{t.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="Grant writing assistance.">
      <p>We help organizations identify the provincial and federal funding available for digital skills training and AI upskilling — and assist with the application process. This service is often what makes a funded partnership possible in the first place.</p>
    </SectionHeading>
    <ul class="grid gap-3 sm:grid-cols-2 list-disc pl-5 text-body text-body-muted">
      <li>Funding source identification for your organization type and community</li>
      <li>Application support and co-writing</li>
      <li>Program design documentation for grant submissions</li>
      <li>Reporting templates for funded programs</li>
    </ul>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="How working with us works.">
      <p>Simple and low-friction from the first conversation to the last session.</p>
    </SectionHeading>
    <Steps steps={steps} />
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="Who we work with.">
      <ul class="grid gap-3 sm:grid-cols-2 list-disc pl-5 text-body text-body-muted">
        {orgTypes.map((o) => <li>{o}</li>)}
      </ul>
    </SectionHeading>
  </section>

  <CTASection title="Let's find the funding for your community.">
    <Fragment slot="body">
      <p>Tell us about your community and we will help you find the funding and the program to match.</p>
      <p class="mt-4"><a href="mailto:holler@weallrize.ca" class="underline hover:no-underline">holler@weallrize.ca</a></p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Get in Touch</Button>
    </Fragment>
  </CTASection>
</BaseLayout>
