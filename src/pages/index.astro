---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import AudiencePicker from '../components/AudiencePicker.astro';
import ProgramCard from '../components/ProgramCard.astro';
import Steps from '../components/Steps.astro';
import CTASection from '../components/CTASection.astro';
import Tape from '../components/Tape.astro';
import Badge from '../components/Badge.astro';
import Photo from '../components/Photo.astro';
import workshopFacilitator from '../assets/images/workshop-facilitator.jpg';
import handsTogether from '../assets/images/hands-together.jpg';
import seniorsCouplePhone from '../assets/images/seniors-couple-phone.jpg';
import collaboratingLaptop from '../assets/images/collaborating-laptop.jpg';
import volunteersFoodBank from '../assets/images/volunteers-food-bank.jpg';
import shopOwners from '../assets/images/shop-owners.jpg';
import vancouverAerial from '../assets/images/vancouver-aerial.jpg';
import nonprofitTeam from '../assets/images/nonprofit-team.jpg';
import cafeOwnersLaptop from '../assets/images/cafe-owners-laptop.jpg';
import learningAtHome from '../assets/images/learning-at-home.jpg';
import handsKeyboard from '../assets/images/hands-keyboard.jpg';

const audiencePaths = [
  {
    heading: 'I represent a community organization, nonprofit, or social service agency.',
    body: 'We partner with organizations like yours to bring funded workshops and courses to the communities you serve — often at little or no cost. Let us show you how it works.',
    ctaLabel: 'Explore Funded Partnerships',
    ctaHref: '/partnerships',
    accent: 'red' as const,
    icon: 'ph:buildings-bold',
    image: nonprofitTeam,
    imageAlt: 'Three nonprofit staff members reviewing program documents together at a shared desk',
  },
  {
    heading: 'I am an entrepreneur, freelancer, or small business owner.',
    body: 'We offer workshops, courses, and systems — websites you own, practical AI, and automation that gives you your time back — designed for people building something. Whether you are just getting started or ready to scale, we can help you use technology to do more of what matters.',
    ctaLabel: 'See Programs and Systems for Entrepreneurs',
    ctaHref: '/services',
    accent: 'ink' as const,
    icon: 'ph:briefcase-bold',
    image: cafeOwnersLaptop,
    imageAlt: 'Two café owners in aprons smiling at something on a laptop behind the counter',
  },
  {
    heading: 'I am an individual looking to build my skills or get support.',
    body: 'Our workshops and courses are open to everyone, and we offer one-on-one teaching and tutoring for people who want personalized support. Accommodating all skill levels.',
    ctaLabel: 'See Our Programs',
    ctaHref: '/learn',
    accent: 'red' as const,
    icon: 'ph:user-bold',
    image: learningAtHome,
    imageAlt: 'A young person wearing headphones working intently at a laptop at home',
  },
];

const steps = [
  {
    title: 'Reach out',
    body: 'Tell us who you are, who your community is, and what you are hoping to achieve. A short conversation is all it takes to get started.',
  },
  {
    title: 'We design together',
    body: 'We work with you to identify the right program, confirm the format, and — where applicable — identify funding sources that can cover the cost.',
  },
  {
    title: 'We show up and deliver',
    body: 'We handle the curriculum, the facilitation, and the materials. Your community shows up and leaves with real skills and real confidence.',
  },
  {
    title: 'You keep the momentum',
    body: 'Every program comes with resources participants can reference independently. For organizations, we are available for follow-up support, ongoing training, or next-step programs.',
  },
];
---
<BaseLayout
  title="Rize Skill Training | Technology Workshops, Courses &amp; Services in Vancouver"
  description="Practical, accessible technology workshops, courses, and services for people, community organizations, and entrepreneurs across Vancouver and the Greater Vancouver area."
>
  <Hero title="The technology is here.<br />Let's make it work for you.">
    <Fragment slot="lead">
      <p>Rize Skill Training offers workshops, courses, and systems that help people, organizations, and entrepreneurs across Vancouver build real confidence with technology — and put it to work for what matters most.</p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/learn">Explore Our Programs</Button>
      <Button href="/partnerships" variant="secondary">Partner With Us</Button>
    </Fragment>
  </Hero>

  <section class="container-wide pt-10 md:pt-14" aria-label="Rize in the community">
    <div class="grid gap-6 sm:grid-cols-3">
      <Photo
        src={workshopFacilitator}
        alt="A Rize facilitator leading a technology workshop for a room of participants"
        class="aspect-[4/3]"
        sizes="(min-width: 640px) 33vw, 100vw"
        loading="eager"
      />
      <Photo
        src={handsTogether}
        alt="A diverse group of people in colorful sweaters stacking their hands together"
        class="aspect-[4/3]"
        sizes="(min-width: 640px) 33vw, 100vw"
        loading="eager"
      />
      <Photo
        src={seniorsCouplePhone}
        alt="A senior couple outdoors smiling at a smartphone together"
        class="aspect-[4/3]"
        sizes="(min-width: 640px) 33vw, 100vw"
        loading="eager"
      />
    </div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="Not sure where to start?">
      <p>Rize serves a few different audiences, and the right path depends on who you are and what you need. Pick the one that fits best.</p>
    </SectionHeading>
    <AudiencePicker paths={audiencePaths} />
  </section>

  <section>
    <div class="container-wide py-16 md:py-24">
      <SectionHeading title="Technology for the people.">
        <p>Technology has the power to change lives, expand reach, and open doors. But that power only lands when people feel confident using it — when it fits the way they already work and the goals they are already chasing.</p>
        <p>Rize Skill Training brings practical, accessible technology education and hands-on builds to individuals and organizations across Vancouver and the Greater Vancouver area — with a focus on the communities, entrepreneurs, and creatives who have the most to gain and have historically had the least support in getting there.</p>
      </SectionHeading>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-[14px] border-2 border-ink bg-ink p-6 text-cream md:col-span-2 md:p-8">
          <div class="flex items-center gap-4">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:arrows-left-right-bold" /></span>
            <h3 class="text-h3">The technology gap</h3>
          </div>
          <p class="mt-4 text-body-lg">There is a technology gap — the distance between what today's tools make possible and what people actually have the time, support, and confidence to use. It is widest for nonprofits, small businesses, and the communities who have historically had the least access. Closing that gap is our whole business.</p>
        </div>
        <div class="relative md:h-full">
          <Photo
            src={collaboratingLaptop}
            alt="Two young colleagues working through a problem together at a laptop"
            class="aspect-[4/3] md:absolute md:inset-0 md:h-full md:aspect-auto"
            sizes="(min-width: 768px) 33vw, 100vw"
          />
        </div>
        <div class="relative md:h-full">
          <Photo
            src={handsKeyboard}
            alt="Hands with silver rings typing on a laptop keyboard, seen from above"
            class="aspect-[4/3] md:absolute md:inset-0 md:h-full md:aspect-auto"
            sizes="(min-width: 768px) 33vw, 100vw"
          />
        </div>
        <div class="rounded-[14px] border-2 border-ink bg-white p-6 md:col-span-2 md:p-8">
          <div class="flex items-center gap-4">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-3xl"><Icon name="ph:compass-bold" /></span>
            <h3 class="text-h3">Guides, not salespeople</h3>
          </div>
          <p class="mt-4 text-body-lg text-body-muted">We are technology guides, not technology salespeople. We filter through the noise to help you figure out which tools and skills you actually need for your work — and which to skip. Then we help you build the confidence, and the systems, that free up your hours for the impact only you can make. The tech is not the thing. Making our communities stronger is the thing.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="What we offer.">
      <p>Our programs run across four learning paths — Everyday Life, Career, Entrepreneurship, and Creative Work — and are available as workshops, multi-session courses, and one-on-one teaching. Every program is built around real outcomes — things you can do, build, or launch when you leave.</p>
    </SectionHeading>
    <div class="grid gap-6 md:grid-cols-2">
      <ProgramCard
        track="community"
        title="Digital Confidence"
        hook="Everyday technology skills for people who want to feel more comfortable and capable online."
        audience="For seniors, newcomers, and anyone ready to get more comfortable with the technology they use every day."
      />
      <ProgramCard
        track="community"
        title="Stay Safe Online"
        hook="Protect yourself from scams, phishing, and the growing wave of digital threats."
        audience="For community members, seniors, and anyone who wants to feel safer and more in control of their digital life."
      />
      <ProgramCard
        track="career"
        title="Future-Proof Your Career"
        hook="Get hired, stay competitive, and build a professional presence that works for you — using AI and modern tools."
        audience="For job seekers, career changers, newcomers entering the Canadian workforce, and anyone ready to take their next step."
      />
      <ProgramCard
        track="career"
        title="AI and Modern Workflows"
        hook="Spend more time on the work only you can do. Let technology support more of the repetitive work around it."
        audience="For entrepreneurs, nonprofit staff, creatives, and small business owners ready to build smarter, faster workflows."
      />
    </div>
    <p class="mt-10 text-lg text-body-muted max-w-2xl">All programs are available through funded community partnerships and on a public schedule. Every program can be tailored to specific groups, industries, and skill levels.</p>
    <div class="mt-6 flex flex-wrap gap-4">
      <Button href="/learn">See All Programs</Button>
      <Button href="/partnerships" variant="secondary">Bring a Program to Your Organization</Button>
    </div>
  </section>

  <Tape text="Let's get ready · Together we rise" />

  <section>
    <div class="container-wide grid gap-10 py-16 md:grid-cols-2 md:items-center md:py-24">
      <div>
        <SectionHeading title="Funded partnerships — bringing programs to your community at little or no cost.">
          <p>Provincial and federal programs are actively funding digital skills and AI upskilling training for specific communities right now. We help you identify the funding that applies to your organization, handle the program design and facilitation, and deliver a workshop or course your community genuinely benefits from — often at little or no cost to you.</p>
          <p>We work with community organizations, nonprofits, Indigenous-led groups, Black community organizations, libraries, employment centers, and social service agencies across Vancouver and the surrounding area.</p>
          <p>You bring the community. We bring the program, the facilitation, and the funding strategy.</p>
        </SectionHeading>
        <div class="mt-6 flex items-center gap-6 flex-wrap">
          <Button href="/partnerships">Explore Funded Partnerships</Button>
          <Badge label="Get ready" />
        </div>
      </div>
      <Photo
        src={volunteersFoodBank}
        alt="Volunteers at a community food bank smiling while carrying boxes of donations"
        class="aspect-[4/5] max-md:aspect-[4/3]"
      />
    </div>
  </section>

  <section class="container-wide py-16 md:py-24">
    <SectionHeading title="How working with us works.">
      <p>Simple and low-friction from the first conversation to the last session.</p>
    </SectionHeading>
    <Steps steps={steps} />
    <div class="mt-10">
      <Button href="/contact">Get in Touch</Button>
    </div>
  </section>

  <section>
    <div class="container-wide grid gap-10 py-16 md:grid-cols-2 md:items-center md:py-24">
      <Photo
        src={shopOwners}
        alt="Two smiling small business owners in aprons standing in their shop"
        class="aspect-[4/3] max-md:order-last"
      />
      <div>
        <SectionHeading title="We build systems, not just sites.">
          <p>Beyond training, we build the systems that make organizations run better — websites your team owns and updates independently, AI put to practical use, and automation that takes the repetitive work off your plate. Connected to the tools you already use, like Slack and HubSpot, and delivered with training so it all stays yours.</p>
          <p>Picture the version of your week where registrations file themselves, one update posts everywhere, and the website answers the common questions. That is the work we do for community organizations, nonprofits, small businesses, and entrepreneurs in Vancouver.</p>
        </SectionHeading>
        <a href="/services" class="font-semibold text-ink underline decoration-brand-red decoration-2 underline-offset-4 hover:decoration-ink">See Our Services &rarr;</a>
      </div>
    </div>
  </section>

  <section class="container-wide grid gap-10 py-16 md:grid-cols-2 md:items-center md:py-24">
    <div>
      <SectionHeading title="Built in East Vancouver. Rooted in community.">
        <p>Rize Skill Training was founded by an AI specialist and educator with over 20 years of experience — and a deep personal commitment to the communities of East Vancouver and the Greater Vancouver area.</p>
        <p>We are grateful to live and work on the unceded territories of the Musqueam, Squamish, and Tsleil-Waututh Nations.</p>
      </SectionHeading>
      <a href="/about" class="font-semibold text-ink underline decoration-brand-red decoration-2 underline-offset-4 hover:decoration-ink">Our Story &rarr;</a>
    </div>
    <Photo
      src={vancouverAerial}
      alt="Aerial view of downtown Vancouver, the harbour, and the mountains beyond"
      class="aspect-[4/3]"
    />
  </section>

  <CTASection title="Ready to get started?">
    <Fragment slot="body">
      <p>Whether you want to bring a program to your community, register for an upcoming session, or explore the systems we build — we would love to hear from you.</p>
      <p class="mt-4"><a href="mailto:holler@weallrize.ca" class="underline hover:no-underline">holler@weallrize.ca</a></p>
    </Fragment>
    <Fragment slot="actions">
      <Button href="/contact">Get in Touch</Button>
    </Fragment>
  </CTASection>
</BaseLayout>
